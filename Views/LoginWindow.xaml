<Window x:Class="FundForest.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FundForest.ViewModels"
        xmlns:h="clr-namespace:FundForest.Helpers"
        Title="FundForest Login" Width="900" Height="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Green Branding Panel -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <Grid>
                    <!-- Decorative circles -->
                    <Ellipse Width="300" Height="300" Fill="{StaticResource PrimaryGreenBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-100,-100,0,0" Opacity="0.4"/>
                    <Ellipse Width="200" Height="200" Fill="{StaticResource AccentGreenBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-60,-60" Opacity="0.3"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <!-- Logo -->
                        <Border Width="72" Height="72" CornerRadius="18"
                                Background="{StaticResource AccentGreenBrush}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="🌿" FontSize="36" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="FundForest" FontSize="32" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,16,0,8"/>

                        <TextBlock Text="Donation Management System"
                                   FontSize="14" Foreground="{StaticResource TextOnDarkMutedBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>

                        <Separator Background="{StaticResource SidebarActiveBrush}" Margin="0,32"/>

                        <TextBlock Text="Managing donations and distributions for a better community."
                                   FontSize="13" Foreground="{StaticResource TextOnDarkMutedBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT: Login Form -->
            <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                <Grid VerticalAlignment="Center" Margin="60,0">
                    <StackPanel>
                        <TextBlock Text="Welcome back" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Sign in to your account" FontSize="14"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,36"/>

                        <!-- Username -->
                        <TextBlock Text="USERNAME" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Height="44" Margin="0,0,0,16"/>

                        <!-- Password -->
                        <TextBlock Text="PASSWORD" Style="{StaticResource FormLabelStyle}"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource ModernPasswordBoxStyle}"
                                     Height="44" Margin="0,0,0,8"/>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" Margin="0,4,0,16"
                                   Visibility="{Binding ErrorMessage, Converter={x:Static h:BoolToVisibilityConverter.Instance}, ConverterParameter=NullCheck}"
                                   TextWrapping="Wrap"/>

                        <!-- Login Button -->
                        <Button Content="Sign In" Height="46"
                                Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="15" Margin="0,8,0,0"
                                Command="{Binding LoginCommand}"
                                CommandParameter="{Binding ElementName=PasswordBox}"/>

                        <!-- Loading -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="Signing in..." FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Close button -->
                <Border.InputBindings>
                    <KeyBinding Key="Escape" Command="{x:Static SystemCommands.CloseWindowCommand}"/>
                </Border.InputBindings>
            </Border>
        </Grid>
    </Border>
</Window>
