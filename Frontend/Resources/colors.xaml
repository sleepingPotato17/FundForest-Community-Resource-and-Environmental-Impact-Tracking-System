<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryGreenColor">#2D6A4F</Color>
    <Color x:Key="PrimaryGreenLightColor">#40916C</Color>
    <Color x:Key="PrimaryGreenDarkColor">#1B4332</Color>
    <Color x:Key="AccentGreenColor">#74C69D</Color>
    <Color x:Key="MintColor">#B7E4C7</Color>
    <Color x:Key="PaleMintColor">#D8F3DC</Color>
    <Color x:Key="BackgroundColor">#F4FAF6</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SidebarColor">#F0F7F1</Color>
    <Color x:Key="SidebarHoverColor">#D8EDDE</Color>
    <Color x:Key="SidebarActiveColor">#C5E3CC</Color>
    <Color x:Key="TextPrimaryColor">#1A2E22</Color>
    <Color x:Key="TextSecondaryColor">#4A6741</Color>
    <Color x:Key="TextMutedColor">#8FAF8A</Color>
    <Color x:Key="TextOnDarkColor">#1B4332</Color>
    <Color x:Key="TextOnDarkMutedColor">#4A6741</Color>
    <Color x:Key="SuccessColor">#52B788</Color>
    <Color x:Key="WarningColor">#F4A261</Color>
    <Color x:Key="DangerColor">#E76F51</Color>
    <Color x:Key="InfoColor">#457B9D</Color>
    <Color x:Key="BorderLightColor">#D8EDDE</Color>
    <Color x:Key="BorderMediumColor">#B7D8C0</Color>

    <SolidColorBrush x:Key="PrimaryGreenBrush"      Color="{StaticResource PrimaryGreenColor}"/>
    <SolidColorBrush x:Key="PrimaryGreenLightBrush" Color="{StaticResource PrimaryGreenLightColor}"/>
    <SolidColorBrush x:Key="PrimaryGreenDarkBrush"  Color="{StaticResource PrimaryGreenDarkColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush"       Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="MintBrush"              Color="{StaticResource MintColor}"/>
    <SolidColorBrush x:Key="PaleMintBrush"          Color="{StaticResource PaleMintColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush"        Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"           Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SidebarBrush"           Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush"      Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush"     Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"       Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"         Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextOnDarkBrush"        Color="{StaticResource TextOnDarkColor}"/>
    <SolidColorBrush x:Key="TextOnDarkMutedBrush"   Color="{StaticResource TextOnDarkMutedColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"           Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"           Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush"            Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush"              Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush"       Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="BorderMediumBrush"      Color="{StaticResource BorderMediumColor}"/>
    <SolidColorBrush x:Key="TransparentBrush"       Color="Transparent"/>

</ResourceDictionary>