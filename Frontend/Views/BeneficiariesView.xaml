<UserControl x:Class="FundForest.Views.BeneficiariesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:FundForest.Helpers"
             Background="#F7FDF9">

    <UserControl.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
        <h:RowNumberConverter x:Key="RowNumberConverter"/>

        <Style x:Key="ChipRadio" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="20" Padding="14,7"
                                BorderThickness="1.5" Cursor="Hand"
                                BorderBrush="#B7E4C7" Background="White">
                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}"
                                       FontSize="12" Foreground="#40916C" FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#2D6A4F" Offset="0"/>
                                            <GradientStop Color="#52B788" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2D6A4F"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D8F3DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Root Grid — table fills full width, modal overlays on top -->
    <Grid>

        <!-- MAIN AREA — always full width -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Padding="28,20,28,16" Background="#F7FDF9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46" Height="46" CornerRadius="14" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1B4332" Offset="0"/>
                                    <GradientStop Color="#52B788" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#1B4332" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <TextBlock Text="👥" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Beneficiaries" FontSize="22" FontWeight="Bold" Foreground="#1B4332"/>
                                <Border CornerRadius="12" Padding="10,3" Margin="10,0,0,0" VerticalAlignment="Center" Background="#D8F3DC">
                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1B4332">
                                        <Run Text="{Binding Beneficiaries.Count, Mode=OneWay}"/>
                                        <Run Text="total"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Manage person and group beneficiaries" FontSize="12" Foreground="#52B788" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1" VerticalAlignment="Center"
                            Command="{Binding AddCommand}"
                            Visibility="{Binding CanAdd, Converter={StaticResource BoolVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="12" Padding="20,12" Cursor="Hand">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1B4332" Offset="0"/>
                                            <GradientStop Color="#52B788" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#1B4332" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                                    </Border.Effect>
                                    <TextBlock Text="+ Add Beneficiary" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="20,0,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Bar -->
                <Border Grid.Row="0" Margin="0,0,0,12" CornerRadius="12"
                        Background="White" BorderBrush="#D8F3DC" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="#1B4332" BlurRadius="8" ShadowDepth="0" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid Margin="16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                     Height="36" BorderThickness="0" Background="Transparent"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="🔍  Search by name, contact, address..."
                                       Foreground="#A8C5B0" FontSize="12"
                                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1" Margin="10,0,0,0" Command="{Binding SearchCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="16,8"
                                            BorderBrush="#52B788" BorderThickness="1.5" Background="Transparent">
                                        <TextBlock Text="Search" FontSize="12" FontWeight="SemiBold" Foreground="#1B4332"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#D8F3DC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- TABLE CARD -->
                <Border Grid.Row="1" CornerRadius="16" Background="White"
                        BorderBrush="#D8F3DC" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="#1B4332" BlurRadius="16" ShadowDepth="2" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Column Headers -->
                        <Border Grid.Row="0" CornerRadius="14,14,0,0" Padding="0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E8F5E9" Offset="0"/>
                                    <GradientStop Color="#F0FAF4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="66"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#"             FontSize="11" FontWeight="Bold" Foreground="#52B788" Margin="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="NAME / GROUP"  FontSize="11" FontWeight="Bold" Foreground="#1B4332" Margin="8,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="TYPE"          FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                                <TextBlock Grid.Column="3" Text="GENDER"        FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                                <TextBlock Grid.Column="4" Text="VULNERABILITY" FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                                <TextBlock Grid.Column="5" Text="CONTACT"       FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                                <TextBlock Grid.Column="6" Text="ADDRESS"       FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                                <TextBlock Grid.Column="7" Text="ACTIONS"       FontSize="11" FontWeight="Bold" Foreground="#1B4332" HorizontalAlignment="Center"
                                           Visibility="{Binding CanEdit, Converter={StaticResource BoolVis}}"/>
                            </Grid>
                        </Border>

                        <!-- Rows -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Beneficiaries}"
                                  SelectedItem="{Binding SelectedBeneficiary}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserResizeRows="False" CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEF7F1"
                                  HeadersVisibility="None" Background="Transparent" BorderThickness="0"
                                  RowHeight="50" SelectionMode="Single"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <!-- FIX: Override system blue selection highlight with green -->
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                         Color="#B7E4C7"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                     Color="#1B4332"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"        Color="#D8F3DC"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"    Color="#1B4332"/>
                            </DataGrid.Resources>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F0FAF4"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E0F5E9"/>
                                            <Setter Property="Foreground" Value="#1B4332"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" Padding="0">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>

                                <!-- FIX: Row number uses ItemContainerGenerator index, not a data property -->
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="32" Height="32" CornerRadius="8"
                                                    Background="#D8F3DC" Margin="16,0,0,0" HorizontalAlignment="Left">
                                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="#1B4332"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                                          Converter={StaticResource RowNumberConverter}}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#1B4332"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                       Margin="8,0,8,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="20" Padding="10,4"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Background="#D8F3DC">
                                                <TextBlock Text="{Binding BeneficiaryType}"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="#1B4332"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Gender}"
                                                       FontSize="12" Foreground="#2D6A4F" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="20" Padding="10,4"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding VulnerabilityType}" Value="Elderly"><Setter Property="Background" Value="#B7E4C7"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding VulnerabilityType}" Value="Senior Citizen"><Setter Property="Background" Value="#B7E4C7"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding VulnerabilityType}" Value="PWD"><Setter Property="Background" Value="#D8F3DC"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding VulnerabilityType}" Value="Indigent"><Setter Property="Background" Value="#95D5B2"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding VulnerabilityType}" Value="Solo Parent"><Setter Property="Background" Value="#B7E4C7"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding VulnerabilityType}" Value="4Ps"><Setter Property="Background" Value="#D8F3DC"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding VulnerabilityType}"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="#1B4332"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ContactInfo}"
                                                       FontSize="12" Foreground="#2D6A4F" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Address}"
                                                       FontSize="12" Foreground="#52B788"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button ToolTip="Edit" Width="32" Height="32" Margin="3,0" Cursor="Hand"
                                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolVis}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" CornerRadius="9" Background="#D8F3DC" BorderBrush="#52B788" BorderThickness="1.5">
                                                                <TextBlock Text="✏" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1B4332"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#B7E4C7"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button ToolTip="Delete" Width="32" Height="32" Margin="3,0" Cursor="Hand"
                                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding DataContext.CanDelete, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolVis}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" CornerRadius="9" Background="#FFF0EE" BorderBrush="#FFD0CC" BorderThickness="1.5">
                                                                <TextBlock Text="🗑" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#FFE0DC"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#E63946"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- MODAL OVERLAY — dim background + centered floating card -->
        <Grid Visibility="{Binding IsFormVisible, Converter={StaticResource BoolVis}}">

            <!-- Dim backdrop -->
            <Border Background="#80000000"/>

            <!-- Centered modal card -->
            <Border Width="520" MaxHeight="640"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="White" CornerRadius="20"
                    BorderBrush="#B7E4C7" BorderThickness="1.5">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Modal Header -->
                    <Border Grid.Row="0" CornerRadius="20,20,0,0" Padding="28,20" BorderBrush="#D8F3DC" BorderThickness="0,0,0,1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E8F5E9" Offset="0"/>
                                <GradientStop Color="#F0FAF4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding FormTitle}" FontSize="18" FontWeight="Bold" Foreground="#1B4332"/>
                                <TextBlock Text="Fill in the details below" FontSize="12" Foreground="#52B788" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Content="✕"
                                    Style="{StaticResource IconButtonStyle}" Command="{Binding CancelCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Modal Fields -->
                    <ScrollViewer Grid.Row="1" Padding="28,20,28,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <TextBlock Text="BENEFICIARY TYPE" Style="{StaticResource FormLabelStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,16">
                                <RadioButton Content="Person" GroupName="BType" Style="{StaticResource ChipRadio}" Margin="0,0,8,0"
                                             IsChecked="{Binding EditingBeneficiary.BeneficiaryType, Converter={h:EnumToBoolConverter}, ConverterParameter=Person}"/>
                                <RadioButton Content="Group" GroupName="BType" Style="{StaticResource ChipRadio}"
                                             IsChecked="{Binding EditingBeneficiary.BeneficiaryType, Converter={h:EnumToBoolConverter}, ConverterParameter=Group}"/>
                            </StackPanel>

                            <!-- PERSON FIELDS -->
                            <StackPanel Visibility="{Binding IsPersonType, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="FULL NAME *" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                                         HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                         Text="{Binding EditingBeneficiary.FullName, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="GENDER" Style="{StaticResource FormLabelStyle}"/>
                                <WrapPanel Margin="0,4,0,14">
                                    <RadioButton Content="Male"         GroupName="Gender" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                                 IsChecked="{Binding EditingBeneficiary.Gender, Converter={h:EnumToBoolConverter}, ConverterParameter=Male}"/>
                                    <RadioButton Content="Female"       GroupName="Gender" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                                 IsChecked="{Binding EditingBeneficiary.Gender, Converter={h:EnumToBoolConverter}, ConverterParameter=Female}"/>
                                    <RadioButton Content="Other"        GroupName="Gender" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                                 IsChecked="{Binding EditingBeneficiary.Gender, Converter={h:EnumToBoolConverter}, ConverterParameter=Other}"/>
                                    <RadioButton Content="None (Group)" GroupName="Gender" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                                 IsChecked="{Binding EditingBeneficiary.Gender, Converter={h:EnumToBoolConverter}, ConverterParameter=None}"/>
                                </WrapPanel>

                                <TextBlock Text="AGE" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                                         HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                         Text="{Binding EditingBeneficiary.Age, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <!-- GROUP FIELDS -->
                            <StackPanel Visibility="{Binding IsGroupType, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="GROUP NAME *" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                                         HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                         Text="{Binding EditingBeneficiary.GroupName, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="NUMBER OF MEMBERS" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                                         HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                         Text="{Binding EditingBeneficiary.NumberOfMembers, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="GROUP REPRESENTATIVE" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                                         HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                         Text="{Binding EditingBeneficiary.GroupRepresentative, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <TextBlock Text="VULNERABILITY TYPE" Style="{StaticResource FormLabelStyle}"/>
                            <WrapPanel Margin="0,4,0,14">
                                <RadioButton Content="None"           GroupName="Vuln" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                             IsChecked="{Binding EditingBeneficiary.VulnerabilityType, Converter={h:EnumToBoolConverter}, ConverterParameter=None}"/>
                                <RadioButton Content="Elderly"        GroupName="Vuln" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                             IsChecked="{Binding EditingBeneficiary.VulnerabilityType, Converter={h:EnumToBoolConverter}, ConverterParameter=Elderly}"/>
                                <RadioButton Content="Senior Citizen" GroupName="Vuln" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                             IsChecked="{Binding EditingBeneficiary.VulnerabilityType, Converter={h:EnumToBoolConverter}, ConverterParameter=Senior Citizen}"/>
                                <RadioButton Content="PWD"            GroupName="Vuln" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                             IsChecked="{Binding EditingBeneficiary.VulnerabilityType, Converter={h:EnumToBoolConverter}, ConverterParameter=PWD}"/>
                                <RadioButton Content="Indigent"       GroupName="Vuln" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                             IsChecked="{Binding EditingBeneficiary.VulnerabilityType, Converter={h:EnumToBoolConverter}, ConverterParameter=Indigent}"/>
                                <RadioButton Content="Solo Parent"    GroupName="Vuln" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                             IsChecked="{Binding EditingBeneficiary.VulnerabilityType, Converter={h:EnumToBoolConverter}, ConverterParameter=Solo Parent}"/>
                                <RadioButton Content="4Ps"            GroupName="Vuln" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                             IsChecked="{Binding EditingBeneficiary.VulnerabilityType, Converter={h:EnumToBoolConverter}, ConverterParameter=4Ps}"/>
                            </WrapPanel>

                            <TextBlock Text="ADDRESS" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                     Height="80" HorizontalAlignment="Stretch"
                                     TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,14"
                                     Text="{Binding EditingBeneficiary.Address, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="CONTACT INFO" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                                     HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                     Text="{Binding EditingBeneficiary.ContactInfo, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="CONTACT DATE" Style="{StaticResource FormLabelStyle}"/>
                            <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                        HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                        SelectedDate="{Binding EditingBeneficiary.ContactDate}"/>

                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#E63946" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,4,0,12"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Modal Footer -->
                    <Border Grid.Row="2" CornerRadius="0,0,20,20" Padding="28,16"
                            BorderBrush="#D8F3DC" BorderThickness="0,1,0,0" Background="#F7FDF9">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Margin="0,0,10,0"
                                    Style="{StaticResource OutlineButtonStyle}" Command="{Binding CancelCommand}"/>
                            <Button Content="Save Beneficiary"
                                    Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
