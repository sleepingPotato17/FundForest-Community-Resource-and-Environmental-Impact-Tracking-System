<Window x:Class="FundForest.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FundForest.ViewModels"
        xmlns:h="clr-namespace:FundForest.Helpers"
        Title="FundForest" Width="980" Height="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
        <h:StringNotEmptyToVisibilityConverter x:Key="StrVis"/>

        <!-- Blob Float 1 -->
        <Storyboard x:Key="BlobFloat1" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Blob1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-35" Duration="0:0:5"/>
            <DoubleAnimation Storyboard.TargetName="Blob1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="20" Duration="0:0:7" AutoReverse="True"/>
        </Storyboard>

        <!-- Blob Float 2 -->
        <Storyboard x:Key="BlobFloat2" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Blob2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="28" Duration="0:0:6"/>
            <DoubleAnimation Storyboard.TargetName="Blob2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="-15" Duration="0:0:8" AutoReverse="True"/>
        </Storyboard>

        <!-- Blob Float 3 -->
        <Storyboard x:Key="BlobFloat3" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Blob3"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-22" Duration="0:0:4"/>
        </Storyboard>

        <!-- Leaf Fall 1 -->
        <Storyboard x:Key="LeafFall1" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Leaf1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-20" To="640" Duration="0:0:9"/>
            <DoubleAnimation Storyboard.TargetName="Leaf1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="45" Duration="0:0:9" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="Leaf1"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.8" Duration="0:0:1"/>
        </Storyboard>

        <!-- Leaf Fall 2 -->
        <Storyboard x:Key="LeafFall2" RepeatBehavior="Forever" BeginTime="0:0:3">
            <DoubleAnimation Storyboard.TargetName="Leaf2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-20" To="640" Duration="0:0:11"/>
            <DoubleAnimation Storyboard.TargetName="Leaf2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="-35" Duration="0:0:11" AutoReverse="True"/>
        </Storyboard>

        <!-- Leaf Fall 3 -->
        <Storyboard x:Key="LeafFall3" RepeatBehavior="Forever" BeginTime="0:0:6">
            <DoubleAnimation Storyboard.TargetName="Leaf3"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-20" To="640" Duration="0:0:8"/>
            <DoubleAnimation Storyboard.TargetName="Leaf3"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="55" Duration="0:0:8" AutoReverse="True"/>
        </Storyboard>

        <!-- Particle 1 -->
        <Storyboard x:Key="Particle1" RepeatBehavior="Forever" BeginTime="0:0:1">
            <DoubleAnimation Storyboard.TargetName="P1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="500" To="-20" Duration="0:0:7"/>
            <DoubleAnimation Storyboard.TargetName="P1"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.7" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>

        <!-- Particle 2 -->
        <Storyboard x:Key="Particle2" RepeatBehavior="Forever" BeginTime="0:0:3">
            <DoubleAnimation Storyboard.TargetName="P2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="400" To="-20" Duration="0:0:9"/>
            <DoubleAnimation Storyboard.TargetName="P2"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.5" Duration="0:0:3" AutoReverse="True"/>
        </Storyboard>

        <!-- Particle 3 -->
        <Storyboard x:Key="Particle3" RepeatBehavior="Forever" BeginTime="0:0:5">
            <DoubleAnimation Storyboard.TargetName="P3"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="550" To="-20" Duration="0:0:8"/>
            <DoubleAnimation Storyboard.TargetName="P3"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.6" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>

        <!-- Logo Pulse -->
        <Storyboard x:Key="LogoPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="1.07" Duration="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="LogoBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="1.07" Duration="0:0:2"/>
        </Storyboard>

        <!-- Tagline Fade In -->
        <Storyboard x:Key="TaglineFadeIn">
            <DoubleAnimation Storyboard.TargetName="TaglineText"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:1.5" BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TaglineText"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="15" To="0" Duration="0:0:1.5" BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Form Slide Up -->
        <Storyboard x:Key="FormFadeIn">
            <DoubleAnimation Storyboard.TargetName="FormCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="FormCard"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="40" To="0" Duration="0:0:1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Gradient Button -->
        <Style x:Key="GradientButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1B4332" Offset="0"/>
                                    <GradientStop Color="#52B788" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#2D6A4F" BlurRadius="18"
                                                  ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#40916C" Offset="0"/>
                                            <GradientStop Color="#74C69D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Glass TextBox -->
        <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="BorderBrush" Value="#50B7E4C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding Tag}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="#52B788"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#52B788"/>
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#52B788" BlurRadius="14"
                                                          ShadowDepth="0" Opacity="0.35"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Glass PasswordBox -->
        <Style x:Key="GlassPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="BorderBrush" Value="#50B7E4C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="#52B788"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#52B788"/>
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#52B788" BlurRadius="14"
                                                          ShadowDepth="0" Opacity="0.35"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Root -->
    <Border CornerRadius="20" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ================================================
                 LEFT PANEL — Nature Immersive
                 ================================================ -->
            <Border Grid.Column="0" ClipToBounds="True">

                <!-- Deep forest gradient base -->
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.8,1">
                        <GradientStop Color="#040D08" Offset="0"/>
                        <GradientStop Color="#0A2318" Offset="0.3"/>
                        <GradientStop Color="#1B4332" Offset="0.65"/>
                        <GradientStop Color="#2D6A4F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Forest tree silhouettes (SVG-style using paths) -->
                    <!-- Tree 1 -->
                    <Path Data="M 60,580 L 60,350 L 30,350 L 80,200 L 130,350 L 100,350 L 100,580 Z"
                          Fill="#0D2B1A" Opacity="0.9"
                          HorizontalAlignment="Left" VerticalAlignment="Bottom"
                          Margin="20,0,0,0"/>
                    <!-- Tree 2 -->
                    <Path Data="M 160,580 L 160,380 L 125,380 L 185,210 L 245,380 L 210,380 L 210,580 Z"
                          Fill="#0A2318" Opacity="0.85"
                          HorizontalAlignment="Left" VerticalAlignment="Bottom"
                          Margin="60,0,0,0"/>
                    <!-- Tree 3 -->
                    <Path Data="M 100,580 L 100,420 L 70,420 L 120,280 L 170,420 L 140,420 L 140,580 Z"
                          Fill="#122D1E" Opacity="0.8"
                          HorizontalAlignment="Left" VerticalAlignment="Bottom"
                          Margin="220,0,0,0"/>
                    <!-- Tree 4 small -->
                    <Path Data="M 60,580 L 60,460 L 40,460 L 75,360 L 110,460 L 90,460 L 90,580 Z"
                          Fill="#0D2B1A" Opacity="0.75"
                          HorizontalAlignment="Left" VerticalAlignment="Bottom"
                          Margin="330,0,0,0"/>
                    <!-- Ground -->
                    <Rectangle Height="60" VerticalAlignment="Bottom"
                               Opacity="0.6">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#0A2318" Offset="0"/>
                                <GradientStop Color="#040D08" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Mist / fog effect -->
                    <Rectangle Height="120" VerticalAlignment="Bottom" Opacity="0.25">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#74C69D" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.Effect>
                            <BlurEffect Radius="20"/>
                        </Rectangle.Effect>
                    </Rectangle>

                    <!-- Animated Blob 1 — top left glow -->
                    <Ellipse x:Name="Blob1" Width="350" Height="350"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-120,-120,0,0" Opacity="0.18">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#52B788" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform>
                            <TranslateTransform/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <BlurEffect Radius="50"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- Animated Blob 2 — bottom right glow -->
                    <Ellipse x:Name="Blob2" Width="300" Height="300"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-80,-80" Opacity="0.15">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#74C69D" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform>
                            <TranslateTransform/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <BlurEffect Radius="40"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- Animated Blob 3 — center glow -->
                    <Ellipse x:Name="Blob3" Width="200" Height="200"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Margin="40,60,0,0" Opacity="0.12">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#B7E4C7" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform>
                            <TranslateTransform/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <BlurEffect Radius="30"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- Light rays -->
                    <Rectangle Width="2" Height="300"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="180,0,0,0" Opacity="0.06"
                               RenderTransformOrigin="0.5,0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#B7E4C7" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="15"/>
                        </Rectangle.RenderTransform>
                        <Rectangle.Effect>
                            <BlurEffect Radius="8"/>
                        </Rectangle.Effect>
                    </Rectangle>

                    <Rectangle Width="2" Height="250"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="280,0,0,0" Opacity="0.05"
                               RenderTransformOrigin="0.5,0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#D8F3DC" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="-10"/>
                        </Rectangle.RenderTransform>
                        <Rectangle.Effect>
                            <BlurEffect Radius="10"/>
                        </Rectangle.Effect>
                    </Rectangle>

                    <Rectangle Width="2" Height="250"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="280,0,0,0" Opacity="0.05"
                               RenderTransformOrigin="0.5,0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#D8F3DC" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="-10"/>
                        </Rectangle.RenderTransform>
                        <Rectangle.Effect>
                            <BlurEffect Radius="10"/>
                        </Rectangle.Effect>
                    </Rectangle>

                    <!-- Floating Leaves -->
                    <TextBlock x:Name="Leaf1" Text="🍃" FontSize="24"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="80,0,0,0" Opacity="0">
                        <TextBlock.RenderTransform>
                            <TranslateTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="Leaf2" Text="🌿" FontSize="18"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="220,0,0,0" Opacity="0.7">
                        <TextBlock.RenderTransform>
                            <TranslateTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="Leaf3" Text="🍃" FontSize="14"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="360,0,0,0" Opacity="0.5">
                        <TextBlock.RenderTransform>
                            <TranslateTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <!-- Particles -->
                    <Ellipse x:Name="P1" Width="5" Height="5" Fill="#80B7E4C7"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="100,0,0,0" Opacity="0">
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                        <Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect>
                    </Ellipse>
                    <Ellipse x:Name="P2" Width="4" Height="4" Fill="#60D8F3DC"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="220,0,0,0" Opacity="0">
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="P3" Width="6" Height="6" Fill="#70B7E4C7"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="340,0,0,0" Opacity="0">
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                        <Ellipse.Effect><BlurEffect Radius="3"/></Ellipse.Effect>
                    </Ellipse>

                    <!-- Main branding content -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="48,0">

                        <!-- Logo -->
                        <Border x:Name="LogoBorder" Width="76" Height="76"
                                CornerRadius="20" HorizontalAlignment="Center"
                                Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#52B788" Offset="0"/>
                                    <GradientStop Color="#1B4332" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#52B788" BlurRadius="28"
                                                  ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <Border.RenderTransform>
                                <ScaleTransform CenterX="38" CenterY="38"/>
                            </Border.RenderTransform>
                            <TextBlock Text="🌿" FontSize="38"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Brand name -->
                        <TextBlock Text="FundForest"
                                   FontSize="38" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <!-- Divider -->
                        <Border Height="1.5" Width="100"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,14" Opacity="0.4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#74C69D" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Tagline -->
                        <TextBlock x:Name="TaglineText"
                                   Text="Transparency that Roots,&#x0a;Impact that Grows"
                                   FontSize="15" FontWeight="Medium"
                                   Foreground="#95D5B2"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   LineHeight="24"
                                   Opacity="0"
                                   Margin="0,0,0,32">
                            <TextBlock.RenderTransform>
                                <TranslateTransform/>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <!-- Stats row -->
                        <Border CornerRadius="14" Padding="20,14"
                                Margin="0,0,0,20">
                            <Border.Background>
                                <SolidColorBrush Color="#18FFFFFF"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#2574C69D"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <UniformGrid Columns="3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="1.2K+" FontSize="20"
                                               FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Donors" FontSize="10"
                                               Foreground="#74C69D"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="500+" FontSize="20"
                                               FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Programs" FontSize="10"
                                               Foreground="#74C69D"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="₱2M+" FontSize="20"
                                               FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Distributed" FontSize="10"
                                               Foreground="#74C69D"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                        </Border>

                        <!-- Pills -->
                        <Border CornerRadius="20" Padding="14,7"
                                HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Border.Background>
                                <SolidColorBrush Color="#2052B788"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#3574C69D"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <TextBlock Text="🔒  Secure &amp; Trusted Platform"
                                       FontSize="12" Foreground="#B7E4C7"/>
                        </Border>
                        <Border CornerRadius="20" Padding="14,7"
                                HorizontalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="#2052B788"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#3574C69D"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <TextBlock Text="🌍  Community Impact Dashboard"
                                       FontSize="12" Foreground="#B7E4C7"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================================================
                 RIGHT PANEL — Login Form
                 ================================================ -->
            <!-- ================================================
     RIGHT PANEL — Dark Forest (matches left panel theme)
     ================================================ -->
            <Border Grid.Column="1" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.8,1">
                        <GradientStop Color="#040D08" Offset="0"/>
                        <GradientStop Color="#0A2318" Offset="0.4"/>
                        <GradientStop Color="#1B4332" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Background decorative blobs -->
                    <Ellipse Width="320" Height="320"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,-100,-100,0" Opacity="0.12">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#52B788" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect><BlurEffect Radius="50"/></Ellipse.Effect>
                    </Ellipse>

                    <Ellipse Width="260" Height="260"
                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="-80,0,0,-80" Opacity="0.10">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#74C69D" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect><BlurEffect Radius="40"/></Ellipse.Effect>
                    </Ellipse>

                    <!-- Close button -->
                    <Button Content="✕" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Margin="0,14,14,0"
                            Width="30" Height="30"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#52B788" FontSize="13"
                            Cursor="Hand" Click="CloseWindow_Click"/>

                    <!-- Glass Form Card -->
                    <Border x:Name="FormCard"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="360" CornerRadius="22"
                            Padding="36,32" Opacity="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A3D2B" Offset="0"/>
                                <GradientStop Color="#122D1E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3A7D5A" Offset="0"/>
                                <GradientStop Color="#1F5C3E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="60"
                                            ShadowDepth="12" Opacity="0.45"
                                            Direction="270"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>

                        <StackPanel>
                            <!-- Header -->
                            <TextBlock Text="Welcome back 👋"
                                    FontSize="26" FontWeight="Bold"
                                    Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="Sign in to continue to FundForest"
                                    FontSize="12" Foreground="#74C69D"
                                    Margin="0,0,0,24"/>

                            <!-- Divider -->
                            <Border Height="1" Margin="0,0,0,22" Opacity="0.2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#74C69D" Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Username -->
                            <TextBlock Text="USERNAME" FontSize="10"
                                    FontWeight="SemiBold" Foreground="#74C69D"
                                    Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource GlassTextBoxDarkStyle}"
                                    Tag="&#xE77B;"
                                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,16"/>

                            <!-- Password -->
                            <TextBlock Text="PASSWORD" FontSize="10"
                                    FontWeight="SemiBold" Foreground="#74C69D"
                                    Margin="0,0,0,6"/>
                            <PasswordBox x:Name="PasswordBox"
                                        Style="{StaticResource GlassPasswordBoxDarkStyle}"
                                        Margin="0,0,0,8"/>

                            <!-- Forgot password -->
                            <TextBlock HorizontalAlignment="Right" Margin="0,0,0,22">
                                <Hyperlink Foreground="#52B788"
                                        TextDecorations="None" FontSize="11"
                                        Click="ForgotPassword_Click">
                                    Forgot Password?
                                </Hyperlink>
                            </TextBlock>

                            <!-- Error -->
                            <Border CornerRadius="8" Padding="12,8"
                                    Margin="0,0,0,14"
                                    Visibility="{Binding ErrorMessage,
                                        Converter={StaticResource StrVis}}">
                                <Border.Background>
                                    <SolidColorBrush Color="#3D1A1A"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#7A2A2A"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <TextBlock Text="{Binding ErrorMessage}"
                                        Foreground="#FF8A80"
                                        FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Sign In -->
                            <Button Content="Sign In  →"
                                    Style="{StaticResource GradientButtonStyle}"
                                    Command="{Binding LoginCommand}"
                                    CommandParameter="{Binding ElementName=PasswordBox}"
                                    Margin="0,0,0,20"/>

                            <!-- Divider -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Height="1"
                                        VerticalAlignment="Center" Opacity="0.2">
                                    <Border.Background>
                                        <SolidColorBrush Color="#74C69D"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Grid.Column="1" Text="or"
                                        FontSize="11" Foreground="#3D6B54"
                                        Margin="12,0"/>
                                <Border Grid.Column="2" Height="1"
                                        VerticalAlignment="Center" Opacity="0.2">
                                    <Border.Background>
                                        <SolidColorBrush Color="#74C69D"/>
                                    </Border.Background>
                                </Border>
                            </Grid>

                            <!-- Create account -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="New to FundForest?  "
                                        FontSize="12" Foreground="#3D6B54"/>
                                <TextBlock FontSize="12">
                                    <Hyperlink Foreground="#74C69D"
                                            FontWeight="SemiBold"
                                            TextDecorations="None"
                                            Click="CreateAccount_Click">
                                        Create Account
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>

                            <!-- Loading -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,10,0,0"
                                        Visibility="{Binding IsLoading,
                                            Converter={StaticResource BoolVis}}">
                                <Ellipse Width="6" Height="6" Fill="#52B788" Margin="3,0"/>
                                <Ellipse Width="6" Height="6" Fill="#52B788" Margin="3,0"/>
                                <Ellipse Width="6" Height="6" Fill="#52B788" Margin="3,0"/>
                                <TextBlock Text="  Signing in..."
                                        FontSize="12" Foreground="#3D6B54"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>