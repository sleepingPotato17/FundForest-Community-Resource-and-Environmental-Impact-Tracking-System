<Window x:Class="FundForest.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FundForest.ViewModels"
        xmlns:h="clr-namespace:FundForest.Helpers"
        Title="FundForest" Width="980" Height="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
        <h:StringNotEmptyToVisibilityConverter x:Key="StrVis"/>

        <Storyboard x:Key="BlobFloat1" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Blob1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-35" Duration="0:0:5"/>
            <DoubleAnimation Storyboard.TargetName="Blob1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="20" Duration="0:0:7" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="BlobFloat2" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Blob2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="28" Duration="0:0:6"/>
            <DoubleAnimation Storyboard.TargetName="Blob2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="-15" Duration="0:0:8" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="BlobFloat3" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Blob3"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-22" Duration="0:0:4"/>
        </Storyboard>
        <Storyboard x:Key="LeafFall1" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Leaf1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-20" To="640" Duration="0:0:9"/>
            <DoubleAnimation Storyboard.TargetName="Leaf1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="45" Duration="0:0:9" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="Leaf1"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.8" Duration="0:0:1"/>
        </Storyboard>
        <Storyboard x:Key="LeafFall2" RepeatBehavior="Forever" BeginTime="0:0:3">
            <DoubleAnimation Storyboard.TargetName="Leaf2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-20" To="640" Duration="0:0:11"/>
            <DoubleAnimation Storyboard.TargetName="Leaf2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="-35" Duration="0:0:11" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="LeafFall3" RepeatBehavior="Forever" BeginTime="0:0:6">
            <DoubleAnimation Storyboard.TargetName="Leaf3"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-20" To="640" Duration="0:0:8"/>
            <DoubleAnimation Storyboard.TargetName="Leaf3"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="55" Duration="0:0:8" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="Particle1" RepeatBehavior="Forever" BeginTime="0:0:1">
            <DoubleAnimation Storyboard.TargetName="P1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="500" To="-20" Duration="0:0:7"/>
            <DoubleAnimation Storyboard.TargetName="P1"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.7" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="Particle2" RepeatBehavior="Forever" BeginTime="0:0:3">
            <DoubleAnimation Storyboard.TargetName="P2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="400" To="-20" Duration="0:0:9"/>
            <DoubleAnimation Storyboard.TargetName="P2"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.5" Duration="0:0:3" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="Particle3" RepeatBehavior="Forever" BeginTime="0:0:5">
            <DoubleAnimation Storyboard.TargetName="P3"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="550" To="-20" Duration="0:0:8"/>
            <DoubleAnimation Storyboard.TargetName="P3"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.6" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="LogoPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="1.07" Duration="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="LogoBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="1.07" Duration="0:0:2"/>
        </Storyboard>
        <Storyboard x:Key="TaglineFadeIn">
            <DoubleAnimation Storyboard.TargetName="TaglineText"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:1.5" BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TaglineText"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="15" To="0" Duration="0:0:1.5" BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="FormFadeIn">
            <DoubleAnimation Storyboard.TargetName="FormCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:1">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="FormCard"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="40" To="0" Duration="0:0:1">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="GradientButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1B4332" Offset="0"/>
                                    <GradientStop Color="#52B788" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#2D6A4F" BlurRadius="18" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#40916C" Offset="0"/>
                                            <GradientStop Color="#74C69D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EyeToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <TextBlock x:Name="EyeIcon"
                                       Text="&#xE7B3;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Foreground="#74C69D"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="EyeIcon" Property="Text" Value="&#xED1A;"/>
                                <Setter TargetName="EyeIcon" Property="Foreground" Value="#40916C"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EyeIcon" Property="Foreground" Value="#40916C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="20" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════ -->
            <!-- LEFT PANEL                                  -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Grid.Column="0" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.8,1">
                        <GradientStop Color="#040D08" Offset="0"/>
                        <GradientStop Color="#0A2318" Offset="0.3"/>
                        <GradientStop Color="#1B4332" Offset="0.65"/>
                        <GradientStop Color="#2D6A4F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Tree silhouettes -->
                    <Path Data="M 60,580 L 60,350 L 30,350 L 80,200 L 130,350 L 100,350 L 100,580 Z"
                          Fill="#0D2B1A" Opacity="0.9" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="20,0,0,0"/>
                    <Path Data="M 160,580 L 160,380 L 125,380 L 185,210 L 245,380 L 210,380 L 210,580 Z"
                          Fill="#0A2318" Opacity="0.85" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="60,0,0,0"/>
                    <Path Data="M 100,580 L 100,420 L 70,420 L 120,280 L 170,420 L 140,420 L 140,580 Z"
                          Fill="#122D1E" Opacity="0.8" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="220,0,0,0"/>
                    <Path Data="M 60,580 L 60,460 L 40,460 L 75,360 L 110,460 L 90,460 L 90,580 Z"
                          Fill="#0D2B1A" Opacity="0.75" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="330,0,0,0"/>
                    <Rectangle Height="60" VerticalAlignment="Bottom" Opacity="0.6">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#0A2318" Offset="0"/>
                                <GradientStop Color="#040D08" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Height="120" VerticalAlignment="Bottom" Opacity="0.25">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#74C69D" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.Effect><BlurEffect Radius="20"/></Rectangle.Effect>
                    </Rectangle>

                    <!-- Blobs -->
                    <Ellipse x:Name="Blob1" Width="350" Height="350"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-120,-120,0,0" Opacity="0.18">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#52B788" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                        <Ellipse.Effect><BlurEffect Radius="50"/></Ellipse.Effect>
                    </Ellipse>
                    <Ellipse x:Name="Blob2" Width="300" Height="300"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-80,-80" Opacity="0.15">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#74C69D" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                        <Ellipse.Effect><BlurEffect Radius="40"/></Ellipse.Effect>
                    </Ellipse>
                    <Ellipse x:Name="Blob3" Width="200" Height="200"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Margin="40,60,0,0" Opacity="0.12">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#B7E4C7" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                        <Ellipse.Effect><BlurEffect Radius="30"/></Ellipse.Effect>
                    </Ellipse>

                    <!-- Falling leaves -->
                    <TextBlock x:Name="Leaf1" Text="🍃" FontSize="24"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="80,0,0,0" Opacity="0">
                        <TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="Leaf2" Text="🌿" FontSize="18"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="220,0,0,0" Opacity="0.7">
                        <TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="Leaf3" Text="🍃" FontSize="14"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="360,0,0,0" Opacity="0.5">
                        <TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform>
                    </TextBlock>

                    <!-- Particles -->
                    <Ellipse x:Name="P1" Width="5" Height="5" Fill="#80B7E4C7"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="100,0,0,0" Opacity="0">
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                        <Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect>
                    </Ellipse>
                    <Ellipse x:Name="P2" Width="4" Height="4" Fill="#60D8F3DC"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="220,0,0,0" Opacity="0">
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="P3" Width="6" Height="6" Fill="#70B7E4C7"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="340,0,0,0" Opacity="0">
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                        <Ellipse.Effect><BlurEffect Radius="3"/></Ellipse.Effect>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="48,0">

                        <!-- Logo -->
                        <Border x:Name="LogoBorder" Width="76" Height="76"
                                CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,20"
                                Background="Transparent">
                            <Border.Effect>
                                <DropShadowEffect Color="#52B788" BlurRadius="28" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <Border.RenderTransform><ScaleTransform CenterX="38" CenterY="38"/></Border.RenderTransform>
                            <Viewbox Width="76" Height="76">
                                <Canvas Width="100" Height="100">
                                    <Ellipse Canvas.Left="15" Canvas.Top="10"
                                             Width="70" Height="65" Opacity="0.3">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#52B788" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                        <Ellipse.Effect><BlurEffect Radius="8"/></Ellipse.Effect>
                                    </Ellipse>
                                    <Path Fill="Transparent" StrokeThickness="5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                        <Path.Stroke>
                                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                                <GradientStop Color="#1B4332" Offset="0"/>
                                                <GradientStop Color="#52B788" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Path.Stroke>
                                        <Path.Data>M50,78 C50,78 16,62 18,28 C18,28 36,34 50,78 Z</Path.Data>
                                    </Path>
                                    <Path Fill="Transparent" StrokeThickness="5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                        <Path.Stroke>
                                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                                <GradientStop Color="#52B788" Offset="0"/>
                                                <GradientStop Color="#95D5B2" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Path.Stroke>
                                        <Path.Data>M50,78 C50,78 84,58 80,18 C80,18 60,26 50,78 Z</Path.Data>
                                        <Path.Effect>
                                            <DropShadowEffect Color="#52B788" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/>
                                        </Path.Effect>
                                    </Path>
                                    <Path StrokeThickness="4"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                        <Path.Stroke>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#74C69D" Offset="0"/>
                                                <GradientStop Color="#1B4332" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Path.Stroke>
                                        <Path.Data>M50,78 Q50,88 50,93</Path.Data>
                                    </Path>
                                </Canvas>
                            </Viewbox>
                        </Border>

                        <!-- Two-tone text -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Fund" FontSize="38" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Forest" FontSize="38" FontWeight="Bold" Foreground="#52B788">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#52B788" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>

                        <Border Height="1.5" Width="100" HorizontalAlignment="Center" Margin="0,14,0,14" Opacity="0.4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#74C69D" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <TextBlock x:Name="TaglineText"
                                   Text="Transparency that Roots,&#x0a;Impact that Grows"
                                   FontSize="15" FontWeight="Medium" Foreground="#95D5B2"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   LineHeight="24" Opacity="0" Margin="0,0,0,32"
                                   FontFamily="Segoe UI">
                            <TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform>
                        </TextBlock>

                        <Border CornerRadius="14" Padding="20,14" Margin="0,0,0,20">
                            <Border.Background><SolidColorBrush Color="#18FFFFFF"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#2574C69D"/></Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <UniformGrid Columns="3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="1.2K+" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Donors" FontSize="10" Foreground="#74C69D" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="500+" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Programs" FontSize="10" Foreground="#74C69D" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="₱2M+" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Distributed" FontSize="10" Foreground="#74C69D" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                        </Border>

                        <Border CornerRadius="20" Padding="14,7" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Border.Background><SolidColorBrush Color="#2052B788"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#3574C69D"/></Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <TextBlock Text="🔒  Secure &amp; Trusted Platform" FontSize="12" Foreground="#B7E4C7"/>
                        </Border>
                        <Border CornerRadius="20" Padding="14,7" HorizontalAlignment="Center">
                            <Border.Background><SolidColorBrush Color="#2052B788"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#3574C69D"/></Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <TextBlock Text="🌍  Community Impact Dashboard" FontSize="12" Foreground="#B7E4C7"/>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- RIGHT PANEL                                 -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Grid.Column="1" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#EEF7F1" Offset="0"/>
                        <GradientStop Color="#E0F0E8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="280" Height="280" HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-80,-80,0" Opacity="0.13">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#52B788" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect><BlurEffect Radius="40"/></Ellipse.Effect>
                    </Ellipse>
                    <Ellipse Width="220" Height="220" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-60,0,0,-60" Opacity="0.1">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#40916C" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect><BlurEffect Radius="35"/></Ellipse.Effect>
                    </Ellipse>

                    <!-- Close button -->
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,14,14,0" Width="30" Height="30"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#74C69D" FontSize="13"
                            Cursor="Hand" Click="CloseWindow_Click"/>

                    <!-- Form Card -->
                    <Border x:Name="FormCard"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Width="370" CornerRadius="24" Padding="38,32" Opacity="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#F4FBF7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#74C69D" Offset="0"/>
                                <GradientStop Color="#B7E4C7" Offset="0.5"/>
                                <GradientStop Color="#52B788" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1.5</Border.BorderThickness>
                        <Border.Effect>
                            <DropShadowEffect Color="#1B4332" BlurRadius="60" ShadowDepth="14" Opacity="0.13" Direction="270"/>
                        </Border.Effect>
                        <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>

                        <StackPanel>

                            <!-- Accent bar -->
                            <Border Width="36" Height="4" CornerRadius="2"
                                    HorizontalAlignment="Left" Margin="0,0,0,20">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1B4332" Offset="0"/>
                                        <GradientStop Color="#52B788" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Header -->
                            <TextBlock Text="Welcome back"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#1B4332" FontFamily="Segoe UI"
                                       Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                                <Border Width="3" Height="14" CornerRadius="2"
                                        Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#52B788" Offset="0"/>
                                            <GradientStop Color="#1B4332" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="Sign in to continue to FundForest"
                                           FontSize="12" Foreground="#52B788"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- USERNAME -->
                            <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#2D6A4F" Margin="0,0,0,6" FontFamily="Segoe UI"/>
                            <Border CornerRadius="14" BorderThickness="1.5" Height="50" Margin="0,0,0,16">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#B7E4C7"/>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F4FBF7" Offset="0"/>
                                        <GradientStop Color="#FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="1" HorizontalAlignment="Right" Background="#D8F3DC"/>
                                    <TextBlock Grid.Column="0" Text="&#xE77B;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="15"
                                               Foreground="#52B788"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Background="Transparent" BorderThickness="0"
                                             FontSize="13" Foreground="#1B4332"
                                             FontFamily="Segoe UI" CaretBrush="#1B4332"
                                             VerticalContentAlignment="Center"
                                             Padding="12,0,12,0"
                                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </Border>

                            <!-- PASSWORD -->
                            <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#2D6A4F" Margin="0,0,0,6" FontFamily="Segoe UI"/>
                            <Border CornerRadius="14" BorderThickness="1.5" Height="50" Margin="0,0,0,8">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#B7E4C7"/>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F4FBF7" Offset="0"/>
                                        <GradientStop Color="#FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="1" HorizontalAlignment="Right" Background="#D8F3DC"/>
                                    <TextBlock Grid.Column="0" Text="&#xE72E;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="15"
                                               Foreground="#52B788"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <PasswordBox x:Name="PasswordBox" Grid.Column="1"
                                                 Background="Transparent" BorderThickness="0"
                                                 FontSize="13" Foreground="#1B4332"
                                                 FontFamily="Segoe UI"
                                                 Padding="12,0,0,0"
                                                 VerticalContentAlignment="Center"
                                                 PasswordChanged="PasswordBox_PasswordChanged">
                                        <PasswordBox.Style>
                                            <Style TargetType="PasswordBox">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChecked, ElementName=LoginEyeToggle}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </PasswordBox.Style>
                                    </PasswordBox>
                                    <TextBox x:Name="RevealPasswordBox" Grid.Column="1"
                                             Background="Transparent" BorderThickness="0"
                                             FontSize="13" Foreground="#1B4332"
                                             FontFamily="Segoe UI" CaretBrush="#1B4332"
                                             Padding="12,0,0,0"
                                             VerticalContentAlignment="Center"
                                             IsReadOnly="True">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChecked, ElementName=LoginEyeToggle}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <ToggleButton x:Name="LoginEyeToggle" Grid.Column="2"
                                                  Style="{StaticResource EyeToggleStyle}"
                                                  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Forgot password -->
                            <TextBlock HorizontalAlignment="Right" Margin="0,0,2,24">
                                <Hyperlink Foreground="#40916C" TextDecorations="None"
                                           FontSize="11" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Click="ForgotPassword_Click">
                                    Forgot Password?
                                </Hyperlink>
                            </TextBlock>

                            <!-- Error -->
                            <Border CornerRadius="10" Padding="12,9" Margin="0,0,0,14"
                                    Background="#FFF0EE" BorderBrush="#FFD0CC" BorderThickness="1"
                                    Visibility="{Binding ErrorMessage, Converter={StaticResource StrVis}}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                    <TextBlock Text="⚠ " Foreground="#C0392B" FontSize="12"
                                            VerticalAlignment="Top" Margin="0,1,0,0"/>
                                    <TextBlock Text="{Binding ErrorMessage}"
                                            Foreground="#C0392B" FontSize="12"
                                            FontFamily="Segoe UI"
                                            TextWrapping="Wrap"
                                            HorizontalAlignment="Left">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Width" Value="240"/>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Sign In Button -->
                            <Button Content="Sign In  →"
                                    Style="{StaticResource GradientButtonStyle}"
                                    Command="{Binding LoginCommand}"
                                    CommandParameter="{Binding ElementName=PasswordBox}"
                                    Margin="0,0,0,20"/>

                            <!-- Divider -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Height="1" Background="#DDE8E0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="or" FontSize="11"
                                           Foreground="#8FAF8A" Margin="12,0" FontFamily="Segoe UI"/>
                                <Border Grid.Column="2" Height="1" Background="#DDE8E0" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Create account -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="New to FundForest?  " FontSize="12"
                                           Foreground="#8FAF8A" FontFamily="Segoe UI"/>
                                <TextBlock FontSize="12" FontFamily="Segoe UI">
                                    <Hyperlink Foreground="#1B4332" FontWeight="Bold"
                                               TextDecorations="None" Click="CreateAccount_Click">
                                        Create Account
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>

                            <!-- Loading -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        Margin="0,12,0,0"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                                <Ellipse Width="6" Height="6" Fill="#52B788" Margin="3,0"/>
                                <Ellipse Width="6" Height="6" Fill="#52B788" Margin="3,0"/>
                                <Ellipse Width="6" Height="6" Fill="#52B788" Margin="3,0"/>
                                <TextBlock Text="  Signing in..." FontSize="12"
                                           Foreground="#8FAF8A" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>