<Window x:Class="FundForest.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FundForest.ViewModels"
        xmlns:h="clr-namespace:FundForest.Helpers"
        Title="FundForest — Create Account" Width="980" Height="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" Background="Transparent">

    <Window.DataContext>
        <vm:RegisterViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
        <h:StringNotEmptyToVisibilityConverter x:Key="StrVis"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2D6A4F"/>
            <Setter Property="Margin" Value="2,0,0,5"/>
            <Setter Property="FontStretch" Value="Expanded"/> 
        </Style>

        <Style x:Key="GradientButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1B4332" Offset="0"/>
                                    <GradientStop Color="#52B788" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#2D6A4F" BlurRadius="18"
                                                  ShadowDepth="3" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="BorderBrush" Value="#C8E6C9"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding Tag}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#74C69D"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40916C"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#52B788" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="BorderBrush" Value="#C8E6C9"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#74C69D"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40916C"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#52B788" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Visual border (purely display, non-interactive) -->
                            <Border x:Name="Bd" CornerRadius="10"
                                    Background="White"
                                    BorderBrush="#C8E6C9"
                                    BorderThickness="1.5"
                                    IsHitTestVisible="False">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE748;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="15" Foreground="#74C69D"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1"
                                                    Content="{TemplateBinding SelectionBoxItem}"
                                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,4,0"
                                                    IsHitTestVisible="False"/>
                                    <TextBlock Grid.Column="2" Text="&#xE70D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="11" Foreground="#74C69D"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- ToggleButton covers the ENTIRE area — must be on top -->
                            <ToggleButton Focusable="False"
                                        IsChecked="{Binding IsDropDownOpen,
                                            RelativeSource={RelativeSource TemplatedParent},
                                            Mode=TwoWay}"
                                        OverridesDefaultStyle="True"
                                        Background="Transparent"
                                        BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <!-- Fully transparent clickable overlay -->
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- Dropdown Popup -->
                            <Popup x:Name="PART_Popup"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=Bd}"
                                VerticalOffset="4">
                                <Border CornerRadius="10" Background="White"
                                        BorderBrush="#B7E4C7" BorderThickness="1.5"
                                        MinWidth="{Binding ActualWidth,
                                            RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#1B4332" BlurRadius="20"
                                                        ShadowDepth="4" Opacity="0.12"/>
                                    </Border.Effect>
                                    <ScrollViewer Padding="4" MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40916C"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#52B788" BlurRadius="10"
                                                        ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#1B4332"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBd" CornerRadius="7"
                                            Padding="{TemplateBinding Padding}"
                                            Margin="4,2"
                                            Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#D8F3DC"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#B7E4C7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.8,1">
                        <GradientStop Color="#040D08" Offset="0"/>
                        <GradientStop Color="#0A2318" Offset="0.3"/>
                        <GradientStop Color="#1B4332" Offset="0.65"/>
                        <GradientStop Color="#2D6A4F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="44,0">
                    <Border Width="80" Height="80" CornerRadius="22"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#52B788" Offset="0"/>
                                <GradientStop Color="#1B4332" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#52B788" BlurRadius="30"
                                              ShadowDepth="0" Opacity="0.6"/>
                        </Border.Effect>
                        <TextBlock Text="🌿" FontSize="40"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="FundForest" FontSize="36" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>

                    <Border Height="1.5" Width="80" HorizontalAlignment="Center"
                            Margin="0,16,0,16" Opacity="0.35">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#74C69D" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock Text="ACCOUNT ROLES" FontSize="10" FontWeight="Bold"
                               Foreground="#74C69D" HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>

                    <Border Background="#18FFFFFF" CornerRadius="12" Padding="16,12" Margin="0,0,0,8"
                            BorderBrush="#25FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#25FFFFFF" Margin="0,0,12,0">
                                <TextBlock Text="🛡️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Admin" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Full access to all features" FontSize="11" Foreground="#95D5B2" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#18FFFFFF" CornerRadius="12" Padding="16,12" Margin="0,0,0,8"
                            BorderBrush="#25FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#25FFFFFF" Margin="0,0,12,0">
                                <TextBlock Text="✏️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Staff" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Can edit and update records" FontSize="11" Foreground="#95D5B2" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#18FFFFFF" CornerRadius="12" Padding="16,12"
                            BorderBrush="#25FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#25FFFFFF" Margin="0,0,12,0">
                                <TextBlock Text="👁️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Local" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="View only access" FontSize="11" Foreground="#95D5B2" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0FAF4" Offset="0"/>
                        <GradientStop Color="#E8F5E9" Offset="0.5"/>
                        <GradientStop Color="#D8F3DC" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,14,0"
                            Width="32" Height="32" Cursor="Hand" Background="Transparent" BorderThickness="0"
                            Foreground="#74C69D" FontSize="13" Click="CloseWindow_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="8" Background="Transparent" BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#D8F3DC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>



                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" VerticalAlignment="Center">
                        <Border HorizontalAlignment="Center" Width="360" CornerRadius="20" Padding="36,32" Margin="0,20">
                            <Border.Background>
                                <SolidColorBrush Color="#FAFFFE"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#B7E4C7" Offset="0"/>
                                    <GradientStop Color="#D8F3DC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1.5</Border.BorderThickness>
                            <Border.Effect>
                                <DropShadowEffect Color="#1B4332" BlurRadius="40" ShadowDepth="8" Opacity="0.1" Direction="270"/>
                            </Border.Effect>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Create Account" FontSize="23" FontWeight="Bold" Foreground="#1B4332"/>
                                    <TextBlock Text=" 🌱" FontSize="23" Margin="2,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="Fill in your details to get started" FontSize="12" Foreground="#74C69D" Margin="0,0,0,24"/>

                                <TextBlock Text="FULL NAME" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource GlassTextBoxStyle}" Tag="&#xE77B;"
                                         Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                                <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource GlassTextBoxStyle}" Tag="&#xE77B;"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                                <TextBlock Text="ROLE" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="RoleComboBox" Style="{StaticResource GlassComboBoxStyle}" Margin="0,0,0,14">
                                    <ComboBoxItem Content="Staff"/>
                                    <ComboBoxItem Content="Local" IsSelected="True"/>
                                </ComboBox>

                                <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="PwdBox" Style="{StaticResource GlassPasswordBoxStyle}" Margin="0,0,0,14"/>

                                <TextBlock Text="CONFIRM PASSWORD" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="ConfirmPwdBox" Style="{StaticResource GlassPasswordBoxStyle}" Margin="0,0,0,16"/>

                                <Border CornerRadius="10" Padding="12,9" Margin="0,0,0,10" Background="#FFF0EE" BorderBrush="#FFD0CC" 
                                        BorderThickness="1" Visibility="{Binding ErrorMessage, Converter={StaticResource StrVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠ " Foreground="#C0392B" FontSize="12"/>
                                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="10" Padding="12,9" Margin="0,0,0,10" Background="#F0FFF4" BorderBrush="#B7E4C7" 
                                        BorderThickness="1" Visibility="{Binding SuccessMessage, Converter={StaticResource StrVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✓ " Foreground="#2D6A4F" FontSize="12"/>
                                        <TextBlock Text="{Binding SuccessMessage}" Foreground="#2D6A4F" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="Create Account  →" Style="{StaticResource GradientButtonStyle}" Margin="0,0,0,14" Click="RegisterButton_Click"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Already have an account?  " FontSize="12" Foreground="#8FAF8A"/>
                                    <TextBlock FontSize="12">
                                        <Hyperlink Foreground="#2D6A4F" FontWeight="SemiBold"
                                                   TextDecorations="None"
                                                   Click="BackToLogin_Click">
                                            Sign In
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>