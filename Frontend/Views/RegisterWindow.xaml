<Window x:Class="FundForest.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FundForest.ViewModels"
        xmlns:h="clr-namespace:FundForest.Helpers"
        Title="FundForest — Create Account" Width="980" Height="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" Background="Transparent">

    <Window.DataContext>
        <vm:RegisterViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
        <h:StringNotEmptyToVisibilityConverter x:Key="StrVis"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4A7C6F"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
            <Setter Property="FontStretch" Value="Expanded"/>
        </Style>

        <Style x:Key="GradientButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1B4332" Offset="0"/>
                                    <GradientStop Color="#2D6A4F" Offset="0.5"/>
                                    <GradientStop Color="#40916C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F2F7F4"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="BorderBrush" Value="#D0E8DA"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding Tag}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="#74C69D"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40916C"/>
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#52B788" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F2F7F4"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="BorderBrush" Value="#D0E8DA"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="#74C69D"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40916C"/>
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#52B788" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="10"
                                    Background="#F2F7F4"
                                    BorderBrush="#D0E8DA"
                                    BorderThickness="1.5"
                                    IsHitTestVisible="False">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE748;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="16" Foreground="#74C69D"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,4,0"
                                                      IsHitTestVisible="False"/>
                                    <TextBlock Grid.Column="2" Text="&#xE70D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" Foreground="#74C69D"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Mode=TwoWay}"
                                          OverridesDefaultStyle="True"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=Bd}"
                                   VerticalOffset="4">
                                <Border CornerRadius="10" Background="White"
                                        BorderBrush="#B7E4C7" BorderThickness="1.5"
                                        MinWidth="{Binding ActualWidth,
                                            RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#1B4332" BlurRadius="20"
                                                          ShadowDepth="4" Opacity="0.12"/>
                                    </Border.Effect>
                                    <ScrollViewer Padding="4" MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40916C"/>
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#1B4332"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBd" CornerRadius="7"
                                            Padding="{TemplateBinding Padding}"
                                            Margin="4,2" Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#D8F3DC"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#B7E4C7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════ LEFT PANEL ══════════════ -->
            <Border Grid.Column="0" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.8,1">
                        <GradientStop Color="#040D08" Offset="0"/>
                        <GradientStop Color="#0A2318" Offset="0.25"/>
                        <GradientStop Color="#0F3D22" Offset="0.55"/>
                        <GradientStop Color="#1B5E38" Offset="0.8"/>
                        <GradientStop Color="#2D6A4F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Ellipse Width="320" Height="420" HorizontalAlignment="Left"
                             VerticalAlignment="Top" Margin="-120,-100,0,0" Opacity="0.06">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#52B788" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="280" Height="360" HorizontalAlignment="Right"
                             VerticalAlignment="Bottom" Margin="0,0,-80,-100" Opacity="0.07">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#40916C" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40,0">

                        <Border Width="84" Height="84" CornerRadius="22"
                                HorizontalAlignment="Center" Margin="0,0,0,18">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2D6A4F" Offset="0"/>
                                    <GradientStop Color="#1B4332" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#52B788" BlurRadius="28"
                                                  ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <TextBlock Text="🌿" FontSize="42"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="FundForest" FontSize="34" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <Border Height="1" Width="60" HorizontalAlignment="Center"
                                Margin="0,12,0,16" Opacity="0.3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#74C69D" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <TextBlock Text="ACCOUNT ROLES" FontSize="10" FontWeight="Bold"
                                   Foreground="#74C69D" HorizontalAlignment="Center"
                                   Margin="0,0,0,16" FontStretch="Expanded"/>

                        <!-- Admin -->
                        <Border Background="#16FFFFFF" CornerRadius="14" Padding="14,11"
                                Margin="0,0,0,8" BorderBrush="#20FFFFFF" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2D6A4F" Offset="0"/>
                                            <GradientStop Color="#40916C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Foreground="#D8F3DC"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Admin" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Full access to all system features and user management"
                                               FontSize="11" Foreground="#95D5B2"
                                               TextWrapping="Wrap" Margin="0,2,0,0" MaxWidth="220"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Staff -->
                        <Border Background="#16FFFFFF" CornerRadius="14" Padding="14,11"
                                Margin="0,0,0,8" BorderBrush="#20FFFFFF" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#40916C" Offset="0"/>
                                            <GradientStop Color="#52B788" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Foreground="#D8F3DC"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Staff" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Edit, update, and manage financial records and projects"
                                               FontSize="11" Foreground="#95D5B2"
                                               TextWrapping="Wrap" Margin="0,2,0,0" MaxWidth="220"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Local -->
                        <Border Background="#16FFFFFF" CornerRadius="14" Padding="14,11"
                                BorderBrush="#20FFFFFF" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#B5893A" Offset="0"/>
                                            <GradientStop Color="#D4A853" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Foreground="#FFF8E7"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Local" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="View-only access for reporting and oversight"
                                               FontSize="11" Foreground="#95D5B2"
                                               TextWrapping="Wrap" Margin="0,2,0,0" MaxWidth="220"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════ RIGHT PANEL ══════════════ -->
            <Border Grid.Column="1" ClipToBounds="True" Background="#FBFEFC">

                <Grid>
                    <!-- Close button -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,14,16,0" Width="32" Height="32"
                            Cursor="Hand" Click="CloseWindow_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="8" Background="Transparent">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Foreground="#74C69D"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#D8F3DC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalAlignment="Center">
                        <StackPanel Margin="52,32,52,32">

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Create Account" FontSize="24"
                                           FontWeight="Bold" Foreground="#1B4332"/>
                                <TextBlock Text=" 🌱" FontSize="22" Margin="4,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="Enter your details to register and get started."
                                       FontSize="12" Foreground="#74C69D" Margin="0,0,0,20"/>

                            <TextBlock Text="FULL NAME" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource GlassTextBoxStyle}"
                                     Tag="&#xE77B;"
                                     Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource GlassTextBoxStyle}"
                                     Tag="&#xE77B;"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="ROLE" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="RoleComboBox"
                                      Style="{StaticResource GlassComboBoxStyle}"
                                      Margin="0,0,0,10">
                                <ComboBoxItem Content="Staff"/>
                                <ComboBoxItem Content="Local" IsSelected="True"/>
                            </ComboBox>

                            <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="PwdBox"
                                         Style="{StaticResource GlassPasswordBoxStyle}"
                                         Margin="0,0,0,10"/>

                            <TextBlock Text="CONFIRM PASSWORD" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="ConfirmPwdBox"
                                         Style="{StaticResource GlassPasswordBoxStyle}"
                                         Margin="0,0,0,14"/>

                            <!-- Error -->
                            <Border CornerRadius="10" Padding="12,9" Margin="0,0,0,8"
                                    Background="#FFF0EE" BorderBrush="#FFD0CC" BorderThickness="1"
                                    Visibility="{Binding ErrorMessage, Converter={StaticResource StrVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠  " Foreground="#C0392B" FontSize="12"/>
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B"
                                               FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Success -->
                            <Border CornerRadius="10" Padding="12,9" Margin="0,0,0,8"
                                    Background="#F0FFF4" BorderBrush="#B7E4C7" BorderThickness="1"
                                    Visibility="{Binding SuccessMessage, Converter={StaticResource StrVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓  " Foreground="#2D6A4F" FontSize="12"/>
                                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#2D6A4F"
                                               FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Button Content="Create Account  →"
                                    Style="{StaticResource GradientButtonStyle}"
                                    Margin="0,0,0,14"
                                    Click="RegisterButton_Click"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Already have an account?  "
                                           FontSize="12" Foreground="#8FAF8A"/>
                                <TextBlock FontSize="12">
                                    <Hyperlink Foreground="#2D6A4F" FontWeight="SemiBold"
                                               TextDecorations="None"
                                               Click="BackToLogin_Click">Sign In</Hyperlink>
                                </TextBlock>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>