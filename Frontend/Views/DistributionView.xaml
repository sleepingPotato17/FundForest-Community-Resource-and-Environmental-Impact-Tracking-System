<UserControl x:Class="FundForest.Views.DistributionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:FundForest.Helpers"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
        <h:StatusToColorConverter x:Key="StatusColor"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Main content -->
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Distribution Manager" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Record and track all distributions to beneficiaries."
                               FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Content="+ Record Distribution"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddCommand}"/>
            </Grid>

            <!-- Search -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="12">
                <Grid>
                    <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="🔍  Search distributions..."
                            Foreground="#A8C5B0"
                            FontSize="13"
                            IsHitTestVisible="False"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding Distributions}"
                          SelectedItem="{Binding SelectedDistribution}"
                          Style="{StaticResource ModernDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource ModernDataGridCellStyle}"
                          RowStyle="{StaticResource ModernDataGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Beneficiary" Binding="{Binding BeneficiaryName}" Width="*"/>
                        <DataGridTextColumn Header="Program"     Binding="{Binding ProgramName}"     Width="130"/>
                        <DataGridTextColumn Header="Item"        Binding="{Binding DistributedItem}" Width="130"/>
                        <DataGridTextColumn Header="Qty"         Binding="{Binding Quantity}"        Width="60"/>
                        <DataGridTextColumn Header="Amount"      Binding="{Binding Amount, StringFormat='₱{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="Date"        Binding="{Binding DistributionDate, StringFormat='MM/dd/yyyy'}" Width="100"/>
                        <DataGridTemplateColumn Header="Status" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" Margin="8,0"
                                            Background="{Binding Status, Converter={StaticResource StatusColor}}">
                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✏" ToolTip="Edit"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.EditCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Foreground="{StaticResource PrimaryGreenBrush}"/>
                                        <Button Content="🗑" ToolTip="Delete" Margin="4,0,0,0"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.DeleteCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Foreground="{StaticResource DangerBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- SIDE FORM PANEL -->
        <Border Grid.Column="1" Width="420"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="24,16"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="{Binding FormTitle}" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button HorizontalAlignment="Right" Content="✕"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding CancelCommand}"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="24,16,24,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- BENEFICIARY -->
                        <TextBlock Text="BENEFICIARY *" Style="{StaticResource FormLabelStyle}"/>
                        <Border CornerRadius="12" BorderThickness="1.5" Margin="0,0,0,14" Background="#F8FFFE">
                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#52B788" BlurRadius="6" ShadowDepth="0" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🧑" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Beneficiaries}"
                                          SelectedValuePath="BeneficiaryID"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding EditingDistribution.BeneficiaryID}"
                                          Background="Transparent" BorderThickness="0"
                                          FontSize="13" Height="42" Foreground="#1B4332"
                                          Margin="0,0,8,0"/>
                            </Grid>
                        </Border>

                        <!-- PROGRAM -->
                        <TextBlock Text="PROGRAM" Style="{StaticResource FormLabelStyle}"/>
                        <Border CornerRadius="12" BorderThickness="1.5" Margin="0,0,0,14" Background="#F8FFFE">
                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#52B788" BlurRadius="6" ShadowDepth="0" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📋" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Programs}"
                                          SelectedValuePath="ProgramID"
                                          DisplayMemberPath="ProgramName"
                                          SelectedValue="{Binding EditingDistribution.ProgramID}"
                                          Background="Transparent" BorderThickness="0"
                                          FontSize="13" Height="42" Foreground="#1B4332"
                                          Margin="0,0,8,0"/>
                            </Grid>
                        </Border>

                        <!-- DISTRIBUTION DATE -->
                        <TextBlock Text="DISTRIBUTION DATE *" Style="{StaticResource FormLabelStyle}"/>
                        <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                    Margin="0,0,0,14"
                                    SelectedDate="{Binding EditingDistribution.DistributionDate}"/>

                        <!-- DISTRIBUTED ITEM -->
                        <TextBlock Text="DISTRIBUTED ITEM" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Height="42" HorizontalAlignment="Stretch"
                                 Text="{Binding EditingDistribution.DistributedItem, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <!-- QUANTITY AND AMOUNT -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="QUANTITY" Style="{StaticResource FormLabelStyle}"/>
                                <Border CornerRadius="12" BorderThickness="1.5" Background="#F8FFFE">
                                    <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="#" FontSize="14" FontWeight="Bold"
                                                   Foreground="#52B788"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0"
                                                 FontSize="13" Height="42" Foreground="#1B4332"
                                                 VerticalContentAlignment="Center" Margin="0,0,8,0"
                                                 Text="{Binding EditingDistribution.Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="AMOUNT (₱)" Style="{StaticResource FormLabelStyle}"/>
                                <Border CornerRadius="12" BorderThickness="1.5" Background="#F8FFFE">
                                    <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="₱" FontSize="14" FontWeight="Bold"
                                                   Foreground="#52B788"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0"
                                                 FontSize="13" Height="42" Foreground="#1B4332"
                                                 VerticalContentAlignment="Center" Margin="0,0,8,0"
                                                 Text="{Binding EditingDistribution.Amount, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- STATUS -->
                        <TextBlock Text="STATUS" Style="{StaticResource FormLabelStyle}"/>
                        <WrapPanel Margin="0,4,0,14">
                            <RadioButton Content="✅ Completed" GroupName="DistStatus" Margin="0,0,8,8"
                                         IsChecked="{Binding EditingDistribution.Status,
                                             Converter={h:EnumToBoolConverter}, ConverterParameter=Completed}">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" CornerRadius="20" Padding="14,7" BorderThickness="1.5" Cursor="Hand">
                                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                                            <Border.Background><SolidColorBrush Color="White"/></Border.Background>
                                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#40916C" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#2D6A4F" Offset="0"/><GradientStop Color="#52B788" Offset="1"/></LinearGradientBrush></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="BorderBrush"><Setter.Value><SolidColorBrush Color="#2D6A4F"/></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="Effect"><Setter.Value><DropShadowEffect Color="#2D6A4F" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/></Setter.Value></Setter>
                                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><SolidColorBrush Color="#D8F3DC"/></Setter.Value></Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton Content="⏳ Pending" GroupName="DistStatus" Margin="0,0,8,8"
                                         IsChecked="{Binding EditingDistribution.Status,
                                             Converter={h:EnumToBoolConverter}, ConverterParameter=Pending}">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" CornerRadius="20" Padding="14,7" BorderThickness="1.5" Cursor="Hand">
                                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                                            <Border.Background><SolidColorBrush Color="White"/></Border.Background>
                                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#40916C" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#2D6A4F" Offset="0"/><GradientStop Color="#52B788" Offset="1"/></LinearGradientBrush></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="BorderBrush"><Setter.Value><SolidColorBrush Color="#2D6A4F"/></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="Effect"><Setter.Value><DropShadowEffect Color="#2D6A4F" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/></Setter.Value></Setter>
                                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><SolidColorBrush Color="#D8F3DC"/></Setter.Value></Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </WrapPanel>

                        <!-- NOTES -->
                        <TextBlock Text="NOTES" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Height="80" HorizontalAlignment="Stretch"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 Text="{Binding EditingDistribution.Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="24,12"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource OutlineButtonStyle}"
                                Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                        <Button Content="Record Distribution" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>