<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="FundForest.Views.ManageUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:FundForest.Helpers"
             Background="#F0FAF4">

    <UserControl.Resources>
        <h:StringNotEmptyToVisibilityConverter x:Key="StrVis"/>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F5E9" Offset="0"/>
                <GradientStop Color="#F0FAF4" Offset="0.5"/>
                <GradientStop Color="#D8F3DC" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,18">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="50" Height="50" CornerRadius="14" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1B4332" Offset="0"/>
                                <GradientStop Color="#52B788" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#1B4332" BlurRadius="14"
                                              ShadowDepth="0" Opacity="0.35"/>
                        </Border.Effect>
                        <TextBlock Text="SP" FontSize="17" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Manage Users" FontSize="22"
                                       FontWeight="Bold" Foreground="#1B4332"/>
                            <Border CornerRadius="12" Padding="10,3" Margin="10,0,0,0"
                                    VerticalAlignment="Center" Background="#D8F3DC">
                                <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1B4332">
                                    <Run Text="{Binding PendingCount, Mode=OneWay}"/>
                                    <Run Text=" pending"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Review and manage system user accounts"
                                   FontSize="12" Foreground="#52B788" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ERROR BANNER -->
            <Border Grid.Row="1" Background="#FFF0EE" BorderBrush="#FFD0CC"
                    BorderThickness="1" CornerRadius="10" Padding="14,10"
                    Margin="0,0,0,12"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StrVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠ " Foreground="#C0392B" FontSize="13"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- TABLE CARD -->
            <Border Grid.Row="2" CornerRadius="16" Background="White"
                    BorderBrush="#D8F3DC" BorderThickness="1.5">
                <Border.Effect>
                    <DropShadowEffect Color="#1B4332" BlurRadius="16"
                                      ShadowDepth="2" Opacity="0.06"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column Header Bar -->
                    <Border Grid.Row="0" CornerRadius="14,14,0,0" Padding="16,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#E8F5E9" Offset="0"/>
                                <GradientStop Color="#F0FAF4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FULL NAME"  FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                            <TextBlock Grid.Column="1" Text="USERNAME"   FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                            <TextBlock Grid.Column="2" Text="ROLE"       FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                            <TextBlock Grid.Column="3" Text="REGISTERED" FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                            <TextBlock Grid.Column="4" Text="STATUS"     FontSize="11" FontWeight="Bold" Foreground="#1B4332"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEF7F1"
                              HeadersVisibility="None"
                              SelectionMode="Single"
                              Background="Transparent"
                              BorderThickness="0"
                              RowHeight="50"
                              RowHeaderWidth="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0FAF4"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E0F5E9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}" Padding="16,0">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FullName}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#1B4332"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Username}"
                                                   FontSize="12" Foreground="#2D6A4F"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="20" Padding="10,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="#D8F3DC">
                                            <TextBlock Text="{Binding Role}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#1B4332"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat=MMM dd yyyy}"
                                                   FontSize="12" Foreground="#52B788"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="20" Padding="10,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                                            <Setter Property="Background" Value="#D8F3DC"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsApproved}" Value="False">
                                                            <Setter Property="Background" Value="#FFF3CD"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusLabel}"
                                                       FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                                                <Setter Property="Foreground" Value="#2D6A4F"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsApproved}" Value="False">
                                                                <Setter Property="Foreground" Value="#856404"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ACTION BUTTONS — full width, no white space -->
            <Border Grid.Row="3" Margin="0,14,0,0" CornerRadius="12"
                    Padding="8,10" Background="White"
                    BorderBrush="#D8F3DC" BorderThickness="1.5">
                <Border.Effect>
                    <DropShadowEffect Color="#1B4332" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.05"/>
                </Border.Effect>
                <UniformGrid Rows="1" Columns="4">

                    <!-- Refresh -->
                    <Button Content="↻  Refresh" Command="{Binding RefreshCommand}"
                            Height="38" Margin="4,0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold" Foreground="#40916C"
                            Background="Transparent" BorderBrush="#B7E4C7" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E8F5E9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Approve -->
                    <Button Content="✓  Approve" Command="{Binding ApproveCommand}"
                            Height="38" Margin="4,0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold" Foreground="White">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1B4332" Offset="0"/>
                                            <GradientStop Color="#52B788" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#1B4332" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Reject -->
                    <Button Content="✕  Reject" Command="{Binding RejectCommand}"
                            Height="38" Margin="4,0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold" Foreground="#C0392B">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10"
                                        Background="#FFF0EE" BorderBrush="#FFD0CC" BorderThickness="1.5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FFD6D6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Delete -->
                    <Button Content="🗑  Delete" Command="{Binding DeleteCommand}"
                            Height="38" Margin="4,0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold" Foreground="White">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10"
                                        Background="#E63946" BorderThickness="0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#E63946" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </UniformGrid>
            </Border>

        </Grid>
    </Grid>
</UserControl>