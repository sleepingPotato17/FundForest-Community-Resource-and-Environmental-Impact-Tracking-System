<UserControl x:Class="FundForest.Views.DonationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:FundForest.Helpers"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
        <h:PesoConverter x:Key="PesoCv"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Main content -->
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Donations" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Record and manage all incoming donations."
                               FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="⬇ Export CSV" Style="{StaticResource OutlineButtonStyle}"
                            Command="{Binding ExportCommand}" Margin="0,0,8,0"/>
                    <Button Content="+ Record Donation" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Filters -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="🔍  Filter by donor name..."
                                Foreground="#A8C5B0"
                                FontSize="13"
                                IsHitTestVisible="False"
                                VerticalAlignment="Center"
                                Margin="16,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Grid.Column="1" Text="From:" VerticalAlignment="Center"
                               Margin="12,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker Grid.Column="2" Style="{StaticResource ModernDatePickerStyle}"
                                SelectedDate="{Binding FilterFrom}" Width="140"/>
                    <TextBlock Grid.Column="3" Text="To:" VerticalAlignment="Center"
                               Margin="12,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker Grid.Column="4" Style="{StaticResource ModernDatePickerStyle}"
                                SelectedDate="{Binding FilterTo}" Width="140"/>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding Donations}"
                          SelectedItem="{Binding SelectedDonation}"
                          Style="{StaticResource ModernDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource ModernDataGridCellStyle}"
                          RowStyle="{StaticResource ModernDataGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Donor Name"  Binding="{Binding DonorName}"     Width="*"/>
                        <DataGridTextColumn Header="Amount"      Binding="{Binding Amount, StringFormat='₱{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Type"        Binding="{Binding DonationType}"   Width="80"/>
                        <DataGridTextColumn Header="Goods Desc." Binding="{Binding GoodsDescription}" Width="150"/>
                        <DataGridTextColumn Header="Date"        Binding="{Binding DonationDate, StringFormat='MM/dd/yyyy'}" Width="110"/>
                        <DataGridTemplateColumn Header="Actions" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✏" ToolTip="Edit"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.EditCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Foreground="{StaticResource PrimaryGreenBrush}"/>
                                        <Button Content="🗑" ToolTip="Delete" Margin="4,0,0,0"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.DeleteCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Foreground="{StaticResource DangerBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- SIDE FORM PANEL -->
        <Border Grid.Column="1" Width="420"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="24,16"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="{Binding FormTitle}" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button HorizontalAlignment="Right" Content="✕"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding CancelCommand}"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="24,16,24,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- DONOR -->
                        <TextBlock Text="DONOR *" Style="{StaticResource FormLabelStyle}"/>
                        <Border CornerRadius="12" BorderThickness="1.5" Margin="0,0,0,14" Background="#F8FFFE">
                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#52B788" BlurRadius="6" ShadowDepth="0" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="👤" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Donors}"
                                          SelectedValuePath="DonorID"
                                          DisplayMemberPath="DonorName"
                                          SelectedValue="{Binding EditingDonation.DonorID}"
                                          Background="Transparent" BorderThickness="0"
                                          FontSize="13" Height="42" Foreground="#1B4332"
                                          Margin="0,0,8,0"/>
                            </Grid>
                        </Border>

                        <!-- DONATION TYPE -->
                        <TextBlock Text="DONATION TYPE" Style="{StaticResource FormLabelStyle}"/>
                        <WrapPanel Margin="0,4,0,14">
                            <RadioButton Content="💵 Cash" GroupName="DonType" Margin="0,0,8,8"
                                         IsChecked="{Binding EditingDonation.DonationType,
                                             Converter={h:EnumToBoolConverter}, ConverterParameter=Cash}">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" CornerRadius="20" Padding="14,7" BorderThickness="1.5" Cursor="Hand">
                                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                                            <Border.Background><SolidColorBrush Color="White"/></Border.Background>
                                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#40916C" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#2D6A4F" Offset="0"/><GradientStop Color="#52B788" Offset="1"/></LinearGradientBrush></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="BorderBrush"><Setter.Value><SolidColorBrush Color="#2D6A4F"/></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="Effect"><Setter.Value><DropShadowEffect Color="#2D6A4F" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/></Setter.Value></Setter>
                                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><SolidColorBrush Color="#D8F3DC"/></Setter.Value></Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton Content="📦 Goods" GroupName="DonType" Margin="0,0,8,8"
                                         IsChecked="{Binding EditingDonation.DonationType,
                                             Converter={h:EnumToBoolConverter}, ConverterParameter=Goods}">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" CornerRadius="20" Padding="14,7" BorderThickness="1.5" Cursor="Hand">
                                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                                            <Border.Background><SolidColorBrush Color="White"/></Border.Background>
                                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#40916C" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#2D6A4F" Offset="0"/><GradientStop Color="#52B788" Offset="1"/></LinearGradientBrush></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="BorderBrush"><Setter.Value><SolidColorBrush Color="#2D6A4F"/></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="Effect"><Setter.Value><DropShadowEffect Color="#2D6A4F" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/></Setter.Value></Setter>
                                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><SolidColorBrush Color="#D8F3DC"/></Setter.Value></Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </WrapPanel>

                        <!-- AMOUNT -->
                        <TextBlock Text="AMOUNT (₱)" Style="{StaticResource FormLabelStyle}"/>
                        <Border CornerRadius="12" BorderThickness="1.5" Margin="0,0,0,14" Background="#F8FFFE">
                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="₱" FontSize="16" FontWeight="Bold"
                                           Foreground="#52B788"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0"
                                         FontSize="14" Height="42" Foreground="#1B4332"
                                         VerticalContentAlignment="Center" Margin="0,0,12,0"
                                         Text="{Binding EditingDonation.Amount, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>

                        <!-- GOODS DESCRIPTION -->
                        <StackPanel Visibility="{Binding IsGoods, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="GOODS DESCRIPTION" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                     Height="80" HorizontalAlignment="Stretch"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Text="{Binding EditingDonation.GoodsDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,14"/>
                        </StackPanel>

                        <!-- DONATION DATE -->
                        <TextBlock Text="DONATION DATE *" Style="{StaticResource FormLabelStyle}"/>
                        <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                    Margin="0,0,0,14"
                                    SelectedDate="{Binding EditingDonation.DonationDate}"/>

                        <!-- NOTES -->
                        <TextBlock Text="NOTES" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Height="80" HorizontalAlignment="Stretch"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 Text="{Binding EditingDonation.Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="24,12"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource OutlineButtonStyle}"
                                Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                        <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>