<UserControl x:Class="FundForest.Views.DonationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:FundForest.Helpers"
             Background="#F7FDF9">

    <UserControl.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
        <h:PesoConverter x:Key="PesoCv"/>
        <h:RowNumberConverter x:Key="RowNumberConverter"/>

        <Style x:Key="TableHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E8F5E9" Offset="0"/>
                        <GradientStop Color="#F0FAF4" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SeparatorVisibility" Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipRadio" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="20" Padding="14,7" BorderThickness="1.5" Cursor="Hand" BorderBrush="#B7E4C7" Background="White">
                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#40916C" FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#2D6A4F" Offset="0"/>
                                            <GradientStop Color="#52B788" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2D6A4F"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D8F3DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="28,20,28,16" Background="#F7FDF9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46" Height="46" CornerRadius="14" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1B4332" Offset="0"/>
                                    <GradientStop Color="#52B788" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect><DropShadowEffect Color="#1B4332" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/></Border.Effect>
                            <TextBlock Text="💵" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Donations" FontSize="22" FontWeight="Bold" Foreground="#1B4332"/>
                                <Border CornerRadius="12" Padding="10,3" Margin="10,0,0,0" VerticalAlignment="Center" Background="#D8F3DC">
                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1B4332">
                                        <Run Text="{Binding Donations.Count, Mode=OneWay}"/>
                                        <Run Text="total"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Record and manage all incoming donations." FontSize="12" Foreground="#52B788" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Margin="0,0,10,0" Command="{Binding ExportCommand}"
                            Visibility="{Binding CanAdd, Converter={StaticResource BoolVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="12" Padding="16,12" Cursor="Hand"
                                            BorderBrush="#52B788" BorderThickness="1.5" Background="Transparent">
                                        <TextBlock Text="⬇ Export PDF" FontSize="13" FontWeight="SemiBold" Foreground="#1B4332"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#D8F3DC"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding AddCommand}" Visibility="{Binding CanAdd, Converter={StaticResource BoolVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="12" Padding="20,12" Cursor="Hand">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#1B4332" Offset="0"/>
                                                <GradientStop Color="#52B788" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect><DropShadowEffect Color="#1B4332" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/></Border.Effect>
                                        <TextBlock Text="+ Record Donation" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.88"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,0,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Bar -->
                <Border Grid.Row="0" Margin="0,0,0,12" CornerRadius="12" Background="White"
                        BorderBrush="#D8F3DC" BorderThickness="1.5">
                    <Border.Effect><DropShadowEffect Color="#1B4332" BlurRadius="8" ShadowDepth="0" Opacity="0.06"/></Border.Effect>
                    <Grid Margin="16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="36"
                                     BorderThickness="0" Background="Transparent"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="🔍  Filter by donor name..." Foreground="#A8C5B0" FontSize="12"
                                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1" Margin="10,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="16,8"
                                            BorderBrush="#52B788" BorderThickness="1.5" Background="Transparent">
                                        <TextBlock Text="Search" FontSize="12" FontWeight="SemiBold" Foreground="#1B4332"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#D8F3DC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Grid.Column="2" Text="From:" VerticalAlignment="Center"
                                   Margin="12,0,6,0" Foreground="#52B788" FontSize="12" FontWeight="SemiBold"/>
                        <DatePicker Grid.Column="3" Style="{StaticResource ModernDatePickerStyle}"
                                    SelectedDate="{Binding FilterFrom}" MinWidth="160" Width="Auto"/>
                        <TextBlock Grid.Column="4" Text="To:" VerticalAlignment="Center"
                                   Margin="12,0,6,0" Foreground="#52B788" FontSize="12" FontWeight="SemiBold"/>
                        <DatePicker Grid.Column="5" Style="{StaticResource ModernDatePickerStyle}"
                                    SelectedDate="{Binding FilterTo}" MinWidth="160" Width="Auto"/>
                    </Grid>
                </Border>

                <!-- TABLE CARD -->
                <Border Grid.Row="1" CornerRadius="16" Background="White" BorderBrush="#D8F3DC" BorderThickness="1.5">
                    <Border.Effect><DropShadowEffect Color="#1B4332" BlurRadius="16" ShadowDepth="2" Opacity="0.06"/></Border.Effect>

                    <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserResizeRows="False" CanUserReorderColumns="False"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEF7F1"
                              HeadersVisibility="Column"
                              ColumnHeaderStyle="{StaticResource TableHeaderStyle}"
                              Background="Transparent" BorderThickness="0"
                              RowHeight="50" SelectionMode="Single"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ItemsSource="{Binding Donations}"
                              SelectedItem="{Binding SelectedDonation}">

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F0FAF4"/></Trigger>
                                    <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#E0F5E9"/></Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}" Padding="0">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <!-- ROW NUMBER -->
                            <DataGridTemplateColumn Width="50" Header="#">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource TableHeaderStyle}">
                                        <Setter Property="Foreground" Value="#52B788"/>
                                        <Setter Property="Padding" Value="16,12"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="32" Height="32" CornerRadius="8"
                                                Background="#D8F3DC" Margin="16,0,0,0" HorizontalAlignment="Left">
                                            <TextBlock FontSize="12" FontWeight="Bold" Foreground="#1B4332"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                                      Converter={StaticResource RowNumberConverter}}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Donor Name -->
                            <DataGridTemplateColumn Width="*" Header="DONOR NAME">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DonorName}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#1B4332" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" Margin="8,0,8,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Amount -->
                            <DataGridTemplateColumn Width="120" Header="AMOUNT">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Amount, StringFormat='₱{0:N2}'}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#1B4332" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Type -->
                            <DataGridTemplateColumn Width="90" Header="TYPE">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="20" Padding="10,4" HorizontalAlignment="Left"
                                                VerticalAlignment="Center" Background="#D8F3DC">
                                            <TextBlock Text="{Binding DonationType}" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="#1B4332"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Goods Description -->
                            <DataGridTemplateColumn Width="150" Header="GOODS DESC.">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding GoodsDescription}" FontSize="12" Foreground="#2D6A4F"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Date -->
                            <DataGridTemplateColumn Width="110" Header="DATE">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DonationDate, StringFormat='MM/dd/yyyy'}"
                                                   FontSize="12" Foreground="#52B788" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Actions — buttons hidden for Local -->
                            <DataGridTemplateColumn Width="110" Header="ACTIONS">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource TableHeaderStyle}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Visibility" Value="{Binding DataContext.CanEdit,
                                            RelativeSource={RelativeSource AncestorType=DataGrid},
                                            Converter={StaticResource BoolVis}}"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Visibility="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolVis}}">
                                            <Button ToolTip="Edit" Width="32" Height="32" Margin="3,0" Cursor="Hand"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" CornerRadius="9" Background="#D8F3DC" BorderBrush="#52B788" BorderThickness="1.5">
                                                            <TextBlock Text="✏" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1B4332"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#B7E4C7"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button ToolTip="Delete" Width="32" Height="32" Margin="3,0" Cursor="Hand"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding DataContext.CanDelete, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolVis}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" CornerRadius="9" Background="#FFF0EE" BorderBrush="#FFD0CC" BorderThickness="1.5">
                                                            <TextBlock Text="🗑" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#FFE0DC"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E63946"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

        <!-- SIDE FORM PANEL -->
        <Border Grid.Column="1" Width="400" Background="White" BorderBrush="#D8F3DC" BorderThickness="1.5,0,0,0"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="24,18" BorderBrush="#D8F3DC" BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E8F5E9" Offset="0"/>
                            <GradientStop Color="#F0FAF4" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding FormTitle}" FontSize="17" FontWeight="Bold" Foreground="#1B4332"/>
                            <TextBlock Text="Fill in the details below" FontSize="12" Foreground="#52B788" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Content="✕" Style="{StaticResource IconButtonStyle}" Command="{Binding CancelCommand}"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" Padding="24,16,24,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="DONOR *" Style="{StaticResource FormLabelStyle}"/>
                        <Border CornerRadius="12" BorderThickness="1.5" Margin="0,0,0,14" Background="White" BorderBrush="#B7E4C7">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="👤" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding Donors}"
                                          SelectedValuePath="DonorID" DisplayMemberPath="DonorName"
                                          SelectedValue="{Binding EditingDonation.DonorID}"
                                          Background="Transparent" BorderThickness="0"
                                          FontSize="13" Height="42" Foreground="#1B4332" Margin="0,0,8,0"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="DONATION TYPE" Style="{StaticResource FormLabelStyle}"/>
                        <WrapPanel Margin="0,4,0,14">
                            <RadioButton Content="💵 Cash" GroupName="DonType" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                         IsChecked="{Binding EditingDonation.DonationType, Converter={h:EnumToBoolConverter}, ConverterParameter=Cash}"/>
                            <RadioButton Content="📦 Goods" GroupName="DonType" Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                         IsChecked="{Binding EditingDonation.DonationType, Converter={h:EnumToBoolConverter}, ConverterParameter=Goods}"/>
                        </WrapPanel>
                        <TextBlock Text="AMOUNT (₱)" Style="{StaticResource FormLabelStyle}"/>
                        <Border CornerRadius="12" BorderThickness="1.5" Margin="0,0,0,14" Background="White" BorderBrush="#B7E4C7">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="₱" FontSize="16" FontWeight="Bold" Foreground="#52B788" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" FontSize="14" Height="42"
                                         Foreground="#1B4332" VerticalContentAlignment="Center" Margin="0,0,12,0"
                                         Text="{Binding EditingDonation.Amount, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>
                        <StackPanel Visibility="{Binding IsGoods, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="GOODS DESCRIPTION" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="80" HorizontalAlignment="Stretch"
                                     TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,14"
                                     Text="{Binding EditingDonation.GoodsDescription, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <TextBlock Text="DONATION DATE *" Style="{StaticResource FormLabelStyle}"/>
                        <DatePicker Style="{StaticResource ModernDatePickerStyle}" Margin="0,0,0,14" SelectedDate="{Binding EditingDonation.DonationDate}"/>
                        <TextBlock Text="NOTES" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="80" HorizontalAlignment="Stretch"
                                 TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,14"
                                 Text="{Binding EditingDonation.Notes, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#E63946" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2" Padding="24,14" BorderBrush="#D8F3DC" BorderThickness="0,1,0,0" Background="#F7FDF9">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource OutlineButtonStyle}" Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
                        <Button Content="Save Donation" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>