<UserControl x:Class="FundForest.Views.DonorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:FundForest.Helpers"
             Background="#F7FDF9">

    <UserControl.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
        <h:RowNumberConverter x:Key="RowNumberConverter"/>

        <Style x:Key="TableHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E8F5E9" Offset="0"/>
                        <GradientStop Color="#F0FAF4" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SeparatorVisibility" Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipRadio" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="20" Padding="14,7"
                                BorderThickness="1.5" Cursor="Hand"
                                BorderBrush="#B7E4C7" Background="White">
                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}"
                                       FontSize="12" Foreground="#40916C" FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#2D6A4F" Offset="0"/>
                                            <GradientStop Color="#52B788" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2D6A4F"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D8F3DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Padding="28,20,28,16" Background="#F7FDF9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46" Height="46" CornerRadius="14" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1B4332" Offset="0"/>
                                    <GradientStop Color="#52B788" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#1B4332" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <TextBlock Text="👤" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Donors" FontSize="22" FontWeight="Bold" Foreground="#1B4332"/>
                                <Border CornerRadius="12" Padding="10,3" Margin="10,0,0,0" VerticalAlignment="Center" Background="#D8F3DC">
                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1B4332">
                                        <Run Text="{Binding Donors.Count, Mode=OneWay}"/>
                                        <Run Text="total"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Track and manage all registered donors." FontSize="12" Foreground="#52B788" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" VerticalAlignment="Center"
                            Command="{Binding AddCommand}"
                            Visibility="{Binding CanAdd, Converter={StaticResource BoolVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="12" Padding="20,12" Cursor="Hand">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1B4332" Offset="0"/>
                                            <GradientStop Color="#52B788" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#1B4332" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                                    </Border.Effect>
                                    <TextBlock Text="+ Add Donor" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="20,0,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Bar -->
                <Border Grid.Row="0" Margin="0,0,0,12" CornerRadius="12"
                        Background="White" BorderBrush="#D8F3DC" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="#1B4332" BlurRadius="8" ShadowDepth="0" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid Margin="16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="36"
                                     BorderThickness="0" Background="Transparent"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="🔍  Search donors..." Foreground="#A8C5B0" FontSize="12"
                                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1" Margin="10,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="16,8"
                                            BorderBrush="#52B788" BorderThickness="1.5" Background="Transparent">
                                        <TextBlock Text="Search" FontSize="12" FontWeight="SemiBold" Foreground="#1B4332"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#D8F3DC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- TABLE CARD -->
                <Border Grid.Row="1" CornerRadius="16" Background="White"
                        BorderBrush="#D8F3DC" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="#1B4332" BlurRadius="16" ShadowDepth="2" Opacity="0.06"/>
                    </Border.Effect>

                    <DataGrid ItemsSource="{Binding Donors}"
                              SelectedItem="{Binding SelectedDonor}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserResizeRows="False" CanUserReorderColumns="False"
                              CanUserResizeColumns="False"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEF7F1"
                              HeadersVisibility="Column"
                              ColumnHeaderStyle="{StaticResource TableHeaderStyle}"
                              Background="Transparent" BorderThickness="0"
                              RowHeight="50" SelectionMode="Single"
                              RowHeaderWidth="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F0FAF4"/></Trigger>
                                    <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#E0F5E9"/></Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}" Padding="0">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <!-- ROW NUMBER -->
                            <DataGridTemplateColumn Width="66" Header="#">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource TableHeaderStyle}">
                                        <Setter Property="Foreground" Value="#52B788"/>
                                        <Setter Property="Padding" Value="16,12"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="32" Height="32" CornerRadius="8"
                                                Background="#D8F3DC" Margin="16,0,0,0" HorizontalAlignment="Left">
                                            <TextBlock FontSize="12" FontWeight="Bold" Foreground="#1B4332"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                                      Converter={StaticResource RowNumberConverter}}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Donor Name -->
                            <DataGridTemplateColumn Width="*" Header="DONOR NAME">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DonorName}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#1B4332" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Type -->
                            <DataGridTemplateColumn Width="120" Header="TYPE">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="20" Padding="10,4" HorizontalAlignment="Left"
                                                VerticalAlignment="Center" Background="#D8F3DC">
                                            <TextBlock Text="{Binding DonationType}" FontSize="11" FontWeight="SemiBold" Foreground="#1B4332"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Contact -->
                            <DataGridTemplateColumn Width="160" Header="CONTACT">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ContactInfo}" FontSize="12" Foreground="#2D6A4F" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Address — fills space when Actions hidden -->
                            <DataGridTemplateColumn Width="*" Header="ADDRESS">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Address}" FontSize="12" Foreground="#52B788"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Actions — buttons hidden for Local via StackPanel Visibility -->
                            <DataGridTemplateColumn Width="110" Header="ACTIONS">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource TableHeaderStyle}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Visibility" Value="{Binding DataContext.CanEdit,
                                            RelativeSource={RelativeSource AncestorType=DataGrid},
                                            Converter={StaticResource BoolVis}}"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Visibility="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolVis}}">
                                            <Button ToolTip="Edit" Width="32" Height="32" Margin="3,0" Cursor="Hand"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" CornerRadius="9" Background="#D8F3DC" BorderBrush="#52B788" BorderThickness="1.5">
                                                            <TextBlock Text="✏" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1B4332"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#B7E4C7"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button ToolTip="Delete" Width="32" Height="32" Margin="3,0" Cursor="Hand"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding DataContext.CanDelete, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolVis}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" CornerRadius="9" Background="#FFF0EE" BorderBrush="#FFD0CC" BorderThickness="1.5">
                                                            <TextBlock Text="🗑" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#FFE0DC"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E63946"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

        <!-- SIDE FORM PANEL -->
        <Border Grid.Column="1" Width="400" Background="White"
                BorderBrush="#D8F3DC" BorderThickness="1.5,0,0,0"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="24,18" BorderBrush="#D8F3DC" BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E8F5E9" Offset="0"/>
                            <GradientStop Color="#F0FAF4" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding FormTitle}" FontSize="17" FontWeight="Bold" Foreground="#1B4332"/>
                            <TextBlock Text="Fill in the details below" FontSize="12" Foreground="#52B788" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Content="✕"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding CancelCommand}"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" Padding="24,16,24,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="DONOR NAME *" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                                 HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                 Text="{Binding EditingDonor.DonorName, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="DONOR TYPE" Style="{StaticResource FormLabelStyle}"/>
                        <WrapPanel Margin="0,4,0,14">
                            <RadioButton Content="👤 Individual" GroupName="DonationType"
                                         Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                         IsChecked="{Binding EditingDonor.DonationType, Converter={h:EnumToBoolConverter}, ConverterParameter=Individual}"/>
                            <RadioButton Content="👥 Group" GroupName="DonationType"
                                         Style="{StaticResource ChipRadio}" Margin="0,0,8,8"
                                         IsChecked="{Binding EditingDonor.DonationType, Converter={h:EnumToBoolConverter}, ConverterParameter=Group}"/>
                        </WrapPanel>
                        <TextBlock Text="CONTACT INFO" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                                 HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                 Text="{Binding EditingDonor.ContactInfo, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="ADDRESS" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="80"
                                 HorizontalAlignment="Stretch" TextWrapping="Wrap"
                                 AcceptsReturn="True" Margin="0,0,0,14"
                                 Text="{Binding EditingDonor.Address, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#E63946"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2" Padding="24,14" BorderBrush="#D8F3DC"
                        BorderThickness="0,1,0,0" Background="#F7FDF9">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource OutlineButtonStyle}"
                                Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
                        <Button Content="Save Donor" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>