<UserControl x:Class="FundForest.Views.DonorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:FundForest.Helpers"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Main content -->
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Manage Donors" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Track and manage all registered donors."
                               FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Content="+ Add Donor"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddCommand}"/>
            </Grid>

            <!-- Search -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="12">
                <Grid>
                    <TextBox Style="{StaticResource ModernTextBoxStyle}" Height="42"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="🔍  Search donors..."
                            Foreground="#A8C5B0"
                            FontSize="13"
                            IsHitTestVisible="False"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding Donors}"
                          SelectedItem="{Binding SelectedDonor}"
                          Style="{StaticResource ModernDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource ModernDataGridCellStyle}"
                          RowStyle="{StaticResource ModernDataGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Donor Name"    Binding="{Binding DonorName}"    Width="*"/>
                        <DataGridTextColumn Header="Type"          Binding="{Binding DonationType}" Width="110"/>
                        <DataGridTextColumn Header="Contact Info"  Binding="{Binding ContactInfo}"  Width="160"/>
                        <DataGridTextColumn Header="Address"       Binding="{Binding Address}"      Width="200"/>
                        <DataGridTemplateColumn Header="Actions" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✏" ToolTip="Edit"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.EditCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Foreground="{StaticResource PrimaryGreenBrush}"/>
                                        <Button Content="🗑" ToolTip="Delete" Margin="4,0,0,0"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.DeleteCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Foreground="{StaticResource DangerBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- SIDE FORM PANEL -->
        <Border Grid.Column="1" Width="420"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="24,16"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="{Binding FormTitle}" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button HorizontalAlignment="Right" Content="✕"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding CancelCommand}"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="24,16,24,0"
                            VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="DONOR NAME *" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                Height="42" HorizontalAlignment="Stretch"
                                Text="{Binding EditingDonor.DonorName, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,0,14"/>

                        <TextBlock Text="DONATION TYPE" Style="{StaticResource FormLabelStyle}"/>
                        <WrapPanel Margin="0,4,0,14">
                            <RadioButton Content="👤 Individual" GroupName="DonationType" Margin="0,0,8,8"
                                        IsChecked="{Binding EditingDonor.DonationType,
                                            Converter={h:EnumToBoolConverter}, ConverterParameter=Individual}">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" CornerRadius="20" Padding="14,7" BorderThickness="1.5" Cursor="Hand">
                                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                                            <Border.Background><SolidColorBrush Color="White"/></Border.Background>
                                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#40916C" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#2D6A4F" Offset="0"/><GradientStop Color="#52B788" Offset="1"/></LinearGradientBrush></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="BorderBrush"><Setter.Value><SolidColorBrush Color="#2D6A4F"/></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="Effect"><Setter.Value><DropShadowEffect Color="#2D6A4F" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/></Setter.Value></Setter>
                                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><SolidColorBrush Color="#D8F3DC"/></Setter.Value></Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton Content="👥 Group" GroupName="DonationType" Margin="0,0,8,8"
                                        IsChecked="{Binding EditingDonor.DonationType,
                                            Converter={h:EnumToBoolConverter}, ConverterParameter=Group}">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" CornerRadius="20" Padding="14,7" BorderThickness="1.5" Cursor="Hand">
                                            <Border.BorderBrush><SolidColorBrush Color="#B7E4C7"/></Border.BorderBrush>
                                            <Border.Background><SolidColorBrush Color="White"/></Border.Background>
                                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#40916C" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#2D6A4F" Offset="0"/><GradientStop Color="#52B788" Offset="1"/></LinearGradientBrush></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="BorderBrush"><Setter.Value><SolidColorBrush Color="#2D6A4F"/></Setter.Value></Setter>
                                                <Setter TargetName="Bd" Property="Effect"><Setter.Value><DropShadowEffect Color="#2D6A4F" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/></Setter.Value></Setter>
                                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"><Setter.Value><SolidColorBrush Color="#D8F3DC"/></Setter.Value></Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </WrapPanel>

                        <TextBlock Text="CONTACT INFO" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                Height="42" HorizontalAlignment="Stretch"
                                Text="{Binding EditingDonor.ContactInfo, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,0,14"/>

                        <TextBlock Text="ADDRESS" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                Height="110" HorizontalAlignment="Stretch"
                                TextWrapping="Wrap" AcceptsReturn="True"
                                Text="{Binding EditingDonor.Address, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,0,14"/>

                        <TextBlock Text="{Binding ErrorMessage}"
                                Foreground="{StaticResource DangerBrush}"
                                FontSize="12" TextWrapping="Wrap"
                                Margin="0,0,0,12"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="24,12"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource OutlineButtonStyle}"
                                Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                        <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
