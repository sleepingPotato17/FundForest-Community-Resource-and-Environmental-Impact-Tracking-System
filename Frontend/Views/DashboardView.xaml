<UserControl x:Class="FundForest.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Dashboard Overview" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Welcome back! Here's what's happening in FundForest."
                               FontSize="13" Foreground="#52B788" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Content="↻  Refresh"
                        Style="{StaticResource OutlineButtonStyle}"
                        Command="{Binding RefreshCommand}"/>
            </Grid>

            <!-- STAT CARDS ROW 1 -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">

                <!-- Beneficiaries -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Total Beneficiaries"
                                       FontSize="10" FontWeight="Bold" FontStretch="Expanded"
                                       Foreground="#2D6A4F" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalBeneficiaries}" FontSize="36"
                                       FontWeight="Bold" Foreground="{StaticResource PrimaryGreenBrush}"/>
                            <TextBlock Text="Individuals &amp; Groups" FontSize="11"
                                       Foreground="#52B788" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12"
                                Background="{StaticResource PaleMintBrush}">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource PrimaryGreenBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Programs -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Active Programs"
                                       FontSize="10" FontWeight="Bold" FontStretch="Expanded"
                                       Foreground="#2D6A4F" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalPrograms}" FontSize="36"
                                       FontWeight="Bold" Foreground="{StaticResource PrimaryGreenBrush}"/>
                            <TextBlock Text="Running programs" FontSize="11"
                                       Foreground="#52B788" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12"
                                Background="{StaticResource PaleMintBrush}">
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource PrimaryGreenBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Donors -->
                <Border Style="{StaticResource StatCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Total Donors"
                                       FontSize="10" FontWeight="Bold" FontStretch="Expanded"
                                       Foreground="#2D6A4F" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalDonors}" FontSize="36"
                                       FontWeight="Bold" Foreground="{StaticResource PrimaryGreenBrush}"/>
                            <TextBlock Text="Registered donors" FontSize="11"
                                       Foreground="#52B788" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12"
                                Background="{StaticResource PaleMintBrush}">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource PrimaryGreenBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- STAT CARDS ROW 2 -->
            <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,24">

                <!-- Total Donations -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Total Donations"
                                       FontSize="10" FontWeight="Bold" FontStretch="Expanded"
                                       Foreground="#2D6A4F" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalDonations}" FontSize="36"
                                       FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}"/>
                            <TextBlock Text="Donation records" FontSize="11"
                                       Foreground="#52B788" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12"
                                Background="#FFF0E8">
                            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource WarningBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Distributions -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Total Distributions"
                                       FontSize="10" FontWeight="Bold" FontStretch="Expanded"
                                       Foreground="#2D6A4F" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalDistributions}" FontSize="36"
                                       FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}"/>
                            <TextBlock Text="Distribution records" FontSize="11"
                                       Foreground="#52B788" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12"
                                Background="#E8F0FF">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource InfoBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Total Amount -->
                <Border Style="{StaticResource StatCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Total Distributed"
                                       FontSize="10" FontWeight="Bold" FontStretch="Expanded"
                                       Foreground="#2D6A4F" Margin="0,0,0,4"/>
                            <TextBlock FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryGreenBrush}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="₱{0:N2}">
                                        <Binding Path="TotalAmountDistributed"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="Completed distributions" FontSize="11"
                                       Foreground="#52B788" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12"
                                Background="{StaticResource PaleMintBrush}">
                            <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource SuccessBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- CHART -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="300"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Donation Activity vs Distribution Activity"
                                       Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Text="Last 6 months" FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource PrimaryGreenBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Donations" Margin="6,0,16,0" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Rectangle Width="14" Height="10" Fill="{StaticResource AccentGreenBrush}"
                                       VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                            <TextBlock Text="Distributions" Margin="6,0,0,0" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding ChartSeries}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        TooltipPosition="Top"/>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>