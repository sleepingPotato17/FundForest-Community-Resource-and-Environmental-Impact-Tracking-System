<Window x:Class="FundForest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FundForest.ViewModels"
        xmlns:views="clr-namespace:FundForest.Views"
        xmlns:h="clr-namespace:FundForest.Helpers"
        Title="FundForest" Width="1280" Height="780"
        MinWidth="1100" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolVis"/>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BeneficiariesViewModel}">
            <views:BeneficiariesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DonorsViewModel}">
            <views:DonorsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DonationsViewModel}">
            <views:DonationsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProgramsViewModel}">
            <views:ProgramsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DistributionViewModel}">
            <views:DistributionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ManageUsersViewModel}">
            <views:ManageUsersView/>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True"
            BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#E8F5E9" Offset="0"/>
                        <GradientStop Color="#F1F8F4" Offset="0.5"/>
                        <GradientStop Color="#FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Decorative blob top-left -->
                    <Ellipse Width="160" Height="160" Opacity="0.18"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-60,-40,0,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#52B788" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Blob1T"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="Blob1T"
                                                         Storyboard.TargetProperty="Y"
                                                         From="0" To="20" Duration="0:0:4"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <!-- Decorative blob bottom-right -->
                    <Ellipse Width="120" Height="120" Opacity="0.12"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-40,-40">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#2D6A4F" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Blob2T"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="Blob2T"
                                                         Storyboard.TargetProperty="Y"
                                                         From="0" To="-20" Duration="0:0:5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <DockPanel LastChildFill="True">

                        <!-- Logo Card -->
                        <Border DockPanel.Dock="Top" Margin="12,16,12,8"
                                CornerRadius="14" Padding="12,10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#D8F3DC" Offset="0"/>
                                    <GradientStop Color="#B7E4C7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#52B788" BlurRadius="16"
                                                  ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10"
                                        Background="#52B788">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#2D6A4F" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1"
                                                        CenterX="18" CenterY="18"/>
                                    </Border.RenderTransform>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="LogoScale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     From="1" To="1.1" Duration="0:0:2"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoScale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     From="1" To="1.1" Duration="0:0:2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <TextBlock Text="🌿" FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="FundForest" FontSize="15" FontWeight="Bold"
                                               Foreground="#1B4332"/>
                                    <TextBlock Text="v1.0" FontSize="9" Foreground="#52B788"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Gradient Divider -->
                        <Rectangle DockPanel.Dock="Top" Height="1" Margin="16,0,16,4" Opacity="0.3">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#52B788" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Bottom Section -->
                        <Border DockPanel.Dock="Bottom" Margin="10,0,10,12">
                            <StackPanel>

                                <!-- Stats Card -->
                                <Border CornerRadius="12" Padding="12,10" Margin="0,0,0,8">
                                    <Border.Background>
                                        <SolidColorBrush Color="#B7E4C7" Opacity="0.3"/>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#52B788" BlurRadius="8"
                                                        ShadowDepth="0" Opacity="0.15"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock FontSize="10" Foreground="#2D6A4F" FontWeight="SemiBold">
                                            <Run Text="🌱 Every donation grows a future."/>
                                        </TextBlock>
                                        <Rectangle Height="1" Margin="0,6,0,6" Opacity="0.3" Fill="#52B788"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TotalDonations}"
                                                        FontSize="16" FontWeight="Bold"
                                                        Foreground="#2D6A4F"/>
                                                <TextBlock Text="Donations" FontSize="9" Foreground="#74C69D"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding TotalPrograms}"
                                                        FontSize="16" FontWeight="Bold"
                                                        Foreground="#2D6A4F"/>
                                                <TextBlock Text="Programs" FontSize="9" Foreground="#74C69D"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>                                <!-- User Card -->
                                <Border CornerRadius="10" Padding="10,8" Margin="0,0,0,8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#D8F3DC" Offset="0"/>
                                            <GradientStop Color="#B7E4C7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="#52B788">
                                            <TextBlock Text="👤" FontSize="15"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AdminName}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Foreground="#1B4332"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding AdminRole}"
                                                       FontSize="9" Foreground="#52B788"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Logout Button -->
                                <Button Height="34" Cursor="Hand"
                                        Command="{Binding LogoutCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="LogoutBd" CornerRadius="8"
                                                    BorderThickness="1"
                                                    BorderBrush="#B7E4C7"
                                                    Background="Transparent">
                                                <TextBlock Text="Log Out" FontSize="12"
                                                           Foreground="#40916C"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="LogoutBd" Property="Background" Value="#E63946"/>
                                                    <Setter TargetName="LogoutBd" Property="BorderBrush" Value="#E63946"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                            </StackPanel>
                        </Border>

                        <!-- Nav Items -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10,8,10,0">
                                <RadioButton Style="{StaticResource NavButtonStyle}"
                                             Content="Dashboard" Tag="&#xE80F;"
                                             GroupName="Nav" IsChecked="True"
                                             Command="{Binding NavDashboardCommand}"/>
                                <RadioButton Style="{StaticResource NavButtonStyle}"
                                             Content="Beneficiaries" Tag="&#xE716;"
                                             GroupName="Nav"
                                             Command="{Binding NavBeneficiariesCommand}"/>
                                <RadioButton Style="{StaticResource NavButtonStyle}"
                                             Content="Programs" Tag="&#xE8F1;"
                                             GroupName="Nav"
                                             Command="{Binding NavProgramsCommand}"/>
                                <RadioButton Style="{StaticResource NavButtonStyle}"
                                             Content="Donors" Tag="&#xE77B;"
                                             GroupName="Nav"
                                             Command="{Binding NavDonorsCommand}"/>
                                <RadioButton Style="{StaticResource NavButtonStyle}"
                                             Content="Donations" Tag="&#xE8C7;"
                                             GroupName="Nav"
                                             Command="{Binding NavDonationsCommand}"/>
                                <RadioButton Style="{StaticResource NavButtonStyle}"
                                             Content="Distribution" Tag="&#xE72C;"
                                             GroupName="Nav"
                                             Command="{Binding NavDistributionCommand}"/>

                                <!-- ✅ Manage Users — Admin only -->
                                <RadioButton Style="{StaticResource NavButtonStyle}"
                                             Content="Manage Users" Tag="&#xE713;"
                                             GroupName="Nav"
                                             Command="{Binding NavManageUsersCommand}"
                                             Visibility="{Binding IsAdmin, Converter={StaticResource BoolVis}}"/>
                            </StackPanel>
                        </ScrollViewer>

                    </DockPanel>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Header Bar -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <Grid Margin="24,0">
                        <TextBlock Text="{Binding CurrentPageName}" VerticalAlignment="Center"
                                   Style="{StaticResource SectionHeaderStyle}" FontSize="16"/>
                        <Border Background="Transparent"
                                MouseLeftButtonDown="Header_MouseDown"
                                Cursor="SizeAll"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="&#xE921;" FontFamily="Segoe MDL2 Assets"
                                    Style="{StaticResource IconButtonStyle}" FontSize="14"
                                    Click="Minimize_Click" ToolTip="Minimize"/>
                            <Button Content="&#xE923;" FontFamily="Segoe MDL2 Assets"
                                    Style="{StaticResource IconButtonStyle}" FontSize="14"
                                    Click="Maximize_Click" ToolTip="Maximize" Margin="4,0"/>
                            <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                    Style="{StaticResource IconButtonStyle}" FontSize="14"
                                    Click="Close_Click" ToolTip="Close"
                                    Foreground="{StaticResource DangerBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" Margin="0"/>
            </Grid>

        </Grid>
    </Border>
</Window>